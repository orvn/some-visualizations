---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Switch from '../../components/Switch.astro';
import { loadGlobal, loadPage } from '../../lib/content';

const global = loadGlobal();
const { meta, content } = loadPage('demoivre-laplace');
const c = content as {
  heading: string;
  eyebrow: string;
  subtitle: string;
};

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: c.heading,
  description: meta.description,
  url: global.url + '/m/demoivre-laplace',
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
>

  <section class="viz-wrap">
    <div class="viz-container" x-data="normalBinomial">

      <p class="eyebrow">{c.eyebrow}</p>
      <h1>{c.heading}</h1>
      <p class="subtitle">{c.subtitle}</p>

      <div class="card">
        <div class="card-header">
          <p class="card-label">De Moivre-Laplace</p>
          <div x-on:change="render()">
            <Switch modelField="continuity" label="continuity correction" />
          </div>
        </div>

        <canvas id="nb-chart"></canvas>

        <div class="slider-group">
          <div class="slider-row">
            <span class="slider-val" x-text="'n = ' + n"></span>
            <input type="range" min="2" max="200" step="1"
                   x-model="n"
                   x-on:input="stopAnimate(); render()"
                   x-bind:disabled="animating" />
          </div>
          <div class="slider-row">
            <span class="slider-val" x-text="'p = ' + parseFloat(p).toFixed(2)"></span>
            <input type="range" min="0.05" max="0.95" step="0.05"
                   x-model="p"
                   x-on:input="render()" />
          </div>
          <button class="btn-animate"
                  x-on:click="animating ? stopAnimate() : animate()"
                  x-text="animating ? 'Stop' : 'Animate'"></button>
        </div>

        <p class="stat-line" x-text="info">&nbsp;</p>
      </div>

      <div class="insight">
        <p class="card-label">Key ideas</p>
        <ul>
          <li><strong>Binomial(n, p) ≈ N(np, np(1−p))</strong> for large n. This is the De Moivre-Laplace theorem.</li>
          <li><strong>Convergence is faster</strong> when p is near 0.5 (symmetric) and slower near 0 or 1 (skewed).</li>
          <li><strong>Continuity correction</strong> improves the approximation by using ℙ(k−0.5 ≤ X ≤ k+0.5) instead of the point PDF.</li>
          <li><strong>Total |error|</strong> shrinks as n grows, confirming convergence.</li>
        </ul>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .viz-wrap {
    padding-block: 2rem 4rem;
  }

  .viz-container {
    max-width: 54rem;
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .eyebrow {
    text-align: center;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--potters-clay);
    margin-bottom: 0.5rem;
  }

  h1 {
    text-align: center;
    font-size: var(--text-3xl);
    font-weight: normal;
    letter-spacing: var(--tracking-tight);
    margin-bottom: 0.5rem;
    color: var(--parchment);
  }

  .subtitle {
    text-align: center;
    color: var(--teak);
    font-size: var(--text-sm);
    margin-bottom: 1.75rem;
  }

  .card {
    background: var(--crow);
    border: 0.0625rem solid var(--bronze);
    border-radius: 0.75rem;
    padding: 1.25rem 1.25rem 0.875rem;
    margin-bottom: 1.25rem;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.875rem;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .card-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--potters-clay);
  }

  canvas {
    display: block;
    width: 100% !important;
  }

  .slider-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-top: 0.875rem;
  }

  .slider-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .slider-val {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: bold;
    color: var(--colonial);
    min-width: 5rem;
  }

  @media (max-width: 30em) {
    .slider-row {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.5rem;
    }

    .btn-animate {
      align-self: flex-end;
    }

    .slider-val {
      min-width: auto;
      font-size: var(--text-sm);
    }
  }

  input[type=range] {
    -webkit-appearance: none;
    appearance: none;
    flex: 1;
    cursor: pointer;
    height: 0.5rem;
    background: transparent;
    padding: 0.75rem 0;
    margin: 0;
  }

  input[type=range]::-webkit-slider-runnable-track {
    height: 0.5rem;
    background: var(--bronze);
    border-radius: 0.25rem;
  }

  input[type=range]::-moz-range-track {
    height: 0.5rem;
    background: var(--bronze);
    border-radius: 0.25rem;
    border: none;
  }

  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 1.5rem;
    height: 1.5rem;
    background: var(--colonial);
    border-radius: 50%;
    border: none;
    margin-top: -0.5rem;
    cursor: pointer;
  }

  input[type=range]::-moz-range-thumb {
    width: 1.5rem;
    height: 1.5rem;
    background: var(--colonial);
    border-radius: 50%;
    border: none;
    cursor: pointer;
  }

  .btn-animate {
    padding: 0.375rem 1rem;
    background: var(--bronze);
    border: 0.0625rem solid var(--potters-clay);
    border-radius: 0.375rem;
    color: var(--parchment);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background-color var(--transition-fast);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .btn-animate:hover {
    background: var(--potters-clay);
  }

  .stat-line {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--teak);
    margin-top: 0.5rem;
    min-height: 1.2em;
  }

  .insight {
    border-top: 0.0625rem solid var(--bronze);
    padding-top: 1.25rem;
  }

  .insight ul {
    color: var(--teak);
    font-size: var(--text-sm);
    line-height: 1.9;
    padding-left: 1.125rem;
  }

  .insight li strong {
    color: var(--parchment);
    font-weight: normal;
  }
</style>
