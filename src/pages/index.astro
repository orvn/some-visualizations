---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadGlobal, loadPage } from '../lib/content';

const global = loadGlobal();
const { meta, content } = loadPage('home');
const c = content as {
  heading: string;
  tagline: string;
};

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: global.name,
  description: global.description,
  url: global.url,
};

const visualizations = [
  {
    title: 'Random Variables',
    description: 'Interactive reference for discrete and continuous distributions with adjustable parameters.',
    category: 'Probability',
    href: '/rv',
  },
  {
    title: 'Normal Distribution & Variance',
    description: 'Interactive visualization of normal distribution curves and how variance controls spread.',
    category: 'Probability',
    href: '/normals',
  },
  {
    title: 'Beta Posterior',
    description: 'Bayesian inference on a coin\'s bias using the beta distribution, visualized across 150 sequential flips.',
    category: 'Probability',
    href: '/beta-posterior',
  },
  {
    title: 'Poisson Process',
    description: 'Arrivals over continuous time with adjustable rate λ, showing interarrival times and cumulative count.',
    category: 'Probability',
    href: '/poisson',
  },
  {
    title: 'Central Limit Theorem',
    description: 'Watch sums of random variables converge to a normal distribution as sample size grows.',
    category: 'Probability',
    href: '/clt',
  },
  {
    title: 'Law of Large Numbers',
    description: 'Sample mean convergence with Markov, Chebyshev, and Chernoff bounds compared.',
    category: 'Probability',
    href: '/lln',
  },
  {
    title: 'Convolution',
    description: 'Animated flip-and-slide showing how the sum of two independent random variables produces a new distribution.',
    category: 'Probability',
    href: '/convolution',
  },
  {
    title: 'Random Incidence',
    description: 'Why randomly sampling a process biases you toward longer intervals. Drop a pin and see the paradox.',
    category: 'Probability',
    href: '/random-incidence',
  },
  {
    title: 'De Moivre-Laplace',
    description: 'The normal approximation to a binomial. Watch the PMF converge to a bell curve as n grows.',
    category: 'Probability',
    href: '/demoivre-laplace',
  },
  {
    title: 'Covariance',
    description: 'How covariance and correlation describe the tendency of two variables to move together.',
    category: 'Probability',
    href: '/covariance',
  },
  {
    title: 'Bivariate Normals',
    description: '3D surface and contour views of joint normal distributions with conditional slicing.',
    category: 'Probability',
    href: '/bivariate-normals',
  },
  {
    title: 'Confidence Intervals',
    description: 'Run 100 experiments to see how confidence intervals capture the true parameter.',
    category: 'Probability',
    href: '/confidence',
  },
];
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
>

  <section class="listing-wrap">
    <div class="container">
      <h1>{c.heading}</h1>
      <p class="tagline">{c.tagline}</p>

      <ul class="viz-grid" role="list">
        {visualizations.map((viz) => (
          <li>
            <a href={viz.href} class="viz-card">
              <p class="viz-category">{viz.category}</p>
              <h2 class="viz-title">{viz.title}</h2>
              <p class="viz-desc">{viz.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

</BaseLayout>

<style>
  .listing-wrap {
    padding-block: 3rem 4rem;
  }

  h1 {
    font-size: var(--text-3xl);
    font-weight: normal;
    color: var(--parchment);
    margin-bottom: 0.5rem;
  }

  .tagline {
    color: var(--teak);
    font-size: var(--text-base);
    margin-bottom: 3rem;
  }

  .viz-grid :global(li) {
    list-style: none;
  }

  .viz-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
    gap: 1.25rem;
  }

  .viz-grid :global(.viz-card) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    height: 100%;
    background: var(--crow);
    border: 0.0625rem solid var(--bronze);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: border-color var(--transition-fast), background-color var(--transition-fast);
  }

  .viz-grid :global(.viz-card:hover) {
    border-color: var(--potters-clay);
    background: var(--clinker);
  }

  .viz-grid :global(.viz-category) {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--potters-clay);
  }

  .viz-grid :global(.viz-title) {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    line-height: 1.25;
    color: var(--parchment);
  }

  .viz-grid :global(.viz-desc) {
    font-size: var(--text-sm);
    color: var(--teak);
    line-height: var(--leading-relaxed);
    margin-top: auto;
  }
</style>

<script is:inline>
(function() {
  function equalizeCards() {
    var cards = document.querySelectorAll('.viz-card');
    if (!cards.length) return;

    // Reset
    cards.forEach(function(c) {
      c.style.minHeight = '';
      var title = c.querySelector('.viz-title');
      if (title) title.style.minHeight = '';
    });

    // Group by row
    var rows = {};
    cards.forEach(function(card) {
      var top = Math.round(card.getBoundingClientRect().top);
      if (!rows[top]) rows[top] = [];
      rows[top].push(card);
    });

    Object.keys(rows).forEach(function(key) {
      var row = rows[key];
      var maxCard = 0;
      var maxTitle = 0;

      row.forEach(function(card) {
        if (card.offsetHeight > maxCard) maxCard = card.offsetHeight;
        var title = card.querySelector('.viz-title');
        if (title && title.offsetHeight > maxTitle) maxTitle = title.offsetHeight;
      });

      row.forEach(function(card) {
        card.style.minHeight = (maxCard / 16) + 'rem';
        var title = card.querySelector('.viz-title');
        if (title) title.style.minHeight = (maxTitle / 16) + 'rem';
      });
    });
  }

  function init() {
    if (!document.querySelector('.viz-grid')) return;
    equalizeCards();
    window.addEventListener('resize', equalizeCards);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
})();
</script>
