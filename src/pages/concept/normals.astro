---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TabNav from '../../components/TabNav.astro';
import { loadGlobal, loadPage } from '../../lib/content';

const global = loadGlobal();
const { meta, content } = loadPage('normals');
const c = content as {
  heading: string;
  eyebrow: string;
  subtitle: string;
};

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: c.heading,
  description: meta.description,
  url: global.url + '/concept/normals',
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
>

  <section class="viz-wrap">
    <div class="viz-container" x-data="normalVariance">

      <p class="eyebrow">{c.eyebrow}</p>
      <h1>{c.heading}</h1>
      <p class="subtitle">{c.subtitle}</p>

      <div class="card">
        <div class="card-header">
          <p class="card-label" x-text="mode === 'a' ? 'Interactive' : 'Reference curves at fixed variances'"></p>
          <TabNav
            modelField="mode"
            options={[
              { value: 'a', label: 'Interactive' },
              { value: 'b', label: 'Reference' },
            ]}
          />
        </div>

        <canvas id="mainChart"></canvas>

        <div class="controls-wrap" x-bind:class="{ 'is-open': mode === 'a' }">
          <div class="controls-inner">
            <div class="slider-row">
              <span class="slider-val">σ² = <span x-text="targetVariance.toFixed(2)"></span></span>
              <input type="range" min="0.1" max="6" step="0.05"
                     x-bind:value="targetVariance"
                     x-on:input="setTarget($event.target.value)" />
              <span class="slider-sigma">σ = <span x-text="Math.sqrt(targetVariance).toFixed(3)"></span></span>
            </div>

            <p class="stat-line">
              Peak height = <span x-text="peak()"></span>
              &nbsp;·&nbsp;
              ≈68% of values fall within ±σ = <em x-text="'±' + Math.sqrt(displayedVariance).toFixed(3)"></em>
            </p>
          </div>
        </div>
      </div>

      <!-- Key intuition -->
      <div class="insight">
        <p class="card-label">Key intuition</p>
        <ul>
          <li><strong>Variance $`\sigma^2 > 0`$ always.</strong> It's the average <em>squared</em> distance from the mean. Squaring eliminates negatives.</li>
          <li><strong>Larger $`\sigma^2`$</strong> → flatter, wider bell → values more spread out, more uncertainty.</li>
          <li><strong>Smaller $`\sigma^2`$</strong> → taller, narrower bell → values cluster tightly around the mean.</li>
          <li><strong>$`\sigma^2 = 0`$</strong> only if the variable is a constant. <strong>$`\sigma^2 < 0`$</strong> is mathematically impossible.</li>
          <li>The area under every curve = 1. Total probability is always 100%, just differently shaped.</li>
        </ul>
        <p class="card-label" style="margin-top: 1rem;">LaTeX test</p>
        <p style="color: var(--teak); font-size: var(--text-sm);">{"Inline: the PDF is $`f(x) = \\frac{1}{\\sigma\\sqrt{2\\pi}} e^{-\\frac{(x-\\mu)^2}{2\\sigma^2}}`$ for all $`x \\in \\mathbb{R}`$."}</p>
        <p style="color: var(--teak); font-size: var(--text-sm);">Display mode:</p>
        <p style="color: var(--teak); font-size: var(--text-sm);">{"$$\\mathbb{E}[X] = \\mu, \\quad \\text{Var}(X) = \\sigma^2$$"}</p>
      </div>

    </div>
  </section>


<script>
  import { renderMath } from '../../lib/notation';
  document.addEventListener('DOMContentLoaded', () => renderMath());
</script>

</BaseLayout>

<style>
  .controls-wrap {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition: grid-template-rows var(--transition-base), opacity var(--transition-base);
    overflow: hidden;
  }

  .controls-wrap.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  .controls-inner {
    overflow: hidden;
  }

  .slider-val {
    min-width: 6.25rem;
  }

  .slider-sigma {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--teak);
    min-width: 5rem;
    text-align: right;
  }

  .stat-line {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--potters-clay);
    margin-top: 0.5rem;
  }

  .stat-line span {
    color: var(--teak);
  }

  .stat-line em {
    color: var(--colonial);
    font-style: normal;
  }
</style>
