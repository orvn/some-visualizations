---
interface Props {
  options: [string, string];
  modelField?: string;
}

const { options, modelField = 'mode' } = Astro.props;
const isRight = `${modelField} === 'b'`;
---

<div
  class="toggle-track"
  x-bind:class={`{ 'is-right': ${isRight} }`}
>
  <button
    class="toggle-option"
    x-bind:class={`{ 'is-active': !(${isRight}) }`}
    x-on:click={`${modelField} = 'a'`}
    type="button"
  >{options[0]}</button>
  <button
    class="toggle-option"
    x-bind:class={`{ 'is-active': ${isRight} }`}
    x-on:click={`${modelField} = 'b'`}
    type="button"
  >{options[1]}</button>
  <span class="toggle-thumb" aria-hidden="true"></span>
</div>

<style>
  .toggle-track {
    position: relative;
    display: inline-flex;
    background: var(--graphite);
    border: 0.0625rem solid var(--bronze);
    border-radius: 0.5rem;
    padding: 0.1875rem;
    gap: 0;
  }

  .toggle-option {
    position: relative;
    z-index: 1;
    padding: 0.375rem 1rem;
    border: none;
    border-radius: 0.375rem;
    background: transparent;
    color: var(--potters-clay);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: color var(--transition-fast);
    white-space: nowrap;
  }

  .toggle-option.is-active {
    color: var(--parchment);
    font-weight: 600;
  }

  .toggle-option:not(.is-active):hover {
    color: var(--teak);
  }

  .toggle-thumb {
    position: absolute;
    top: 0.1875rem;
    left: 0.1875rem;
    width: calc(50% - 0.1875rem);
    height: calc(100% - 0.375rem);
    background: var(--potters-clay);
    border: none;
    border-radius: 0.375rem;
    transition: transform var(--transition-base);
    pointer-events: none;
  }

  .toggle-track.is-right .toggle-thumb {
    transform: translateX(100%);
  }
</style>
