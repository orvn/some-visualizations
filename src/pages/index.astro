---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadGlobal, loadPage } from '../lib/content';

const global = loadGlobal();
const { meta, content } = loadPage('home');
const c = content as {
  heading: string;
  tagline: string;
};

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: global.name,
  description: global.description,
  url: global.url,
};

const visualizations = [
  {
    title: 'Random Variables',
    description: 'Interactive reference for discrete and continuous distributions with adjustable parameters.',
    category: 'Probability',
    href: '/concept/rv',
  },
  {
    title: 'Normal Distribution & Variance',
    description: 'Interactive visualization of normal distribution curves and how variance controls spread.',
    category: 'Probability',
    href: '/concept/normals',
  },
  {
    title: 'Beta Posterior',
    description: 'Bayesian inference on a coin\'s bias using the beta distribution, visualized across 150 sequential flips.',
    category: 'Probability',
    href: '/concept/beta-posterior',
  },
  {
    title: 'Poisson Process',
    description: 'Arrivals over continuous time with adjustable rate λ, showing interarrival times and cumulative count.',
    category: 'Probability',
    href: '/concept/poisson',
  },
  {
    title: 'Memorylessness',
    description: 'The exponential distribution forgets the past. Select any wait time and see the remaining distribution stays identical.',
    category: 'Probability',
    href: '/concept/memorylessness',
  },
  {
    title: 'Central Limit Theorem',
    description: 'Watch sums of random variables converge to a normal distribution as sample size grows.',
    category: 'Probability',
    href: '/concept/clt',
  },
  {
    title: 'Law of Large Numbers',
    description: 'Sample mean convergence with Markov, Chebyshev, and Chernoff bounds compared.',
    category: 'Probability',
    href: '/concept/lln',
  },
  {
    title: 'Convolution',
    description: 'Animated flip-and-slide showing how the sum of two independent random variables produces a new distribution.',
    category: 'Probability',
    href: '/concept/convolution',
  },
  {
    title: 'Random Incidence',
    description: 'Why randomly sampling a process biases you toward longer intervals. Drop a pin and see the paradox.',
    category: 'Probability',
    href: '/concept/random-incidence',
  },
  {
    title: 'De Moivre-Laplace',
    description: 'The normal approximation to a binomial. Watch the PMF converge to a bell curve as n grows.',
    category: 'Probability',
    href: '/concept/demoivre-laplace',
  },
  {
    title: 'Covariance',
    description: 'How covariance and correlation describe the tendency of two variables to move together.',
    category: 'Probability',
    href: '/concept/covariance',
  },
  {
    title: 'Bivariate Normals',
    description: '3D surface and contour views of joint normal distributions with conditional slicing.',
    category: 'Probability',
    href: '/concept/bivariate-normals',
  },
  {
    title: 'Confidence Intervals',
    description: 'Run 100 experiments to see how confidence intervals capture the true parameter.',
    category: 'Probability',
    href: '/concept/confidence',
  },
  {
    title: 'Markov Chains',
    description: 'Interactive state diagram with animated random walks. Watch steady-state probabilities emerge.',
    category: 'Probability',
    href: '/concept/markov',
  },
];
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
>

  <section class="listing-wrap">
    <div class="container">
      <h1>{c.heading}</h1>
      <p class="tagline">{c.tagline}</p>

      <ul class="viz-grid" role="list">
        {visualizations.map((viz) => (
          <li>
            <a href={viz.href} class="viz-card">
              <p class="viz-category">{viz.category}</p>
              <h2 class="viz-title">{viz.title}</h2>
              <p class="viz-desc">{viz.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

</BaseLayout>

<style>
  .listing-wrap {
    padding-block: 3rem 4rem;
  }

  h1 {
    font-size: var(--text-3xl);
    font-weight: normal;
    color: var(--parchment);
    margin-bottom: 0.5rem;
  }

  .tagline {
    color: var(--teak);
    font-size: var(--text-base);
    margin-bottom: 3rem;
  }

  .viz-grid :global(li) {
    list-style: none;
  }

  .viz-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
    gap: 1.25rem;
  }

  .viz-grid :global(.viz-card) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    height: 100%;
    background: var(--crow);
    border: 0.0625rem solid var(--bronze);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: border-color var(--transition-fast), background-color var(--transition-fast);
  }

  .viz-grid :global(.viz-card:hover) {
    border-color: var(--potters-clay);
    background: var(--clinker);
  }

  .viz-grid :global(.viz-category) {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--potters-clay);
  }

  .viz-grid :global(.viz-title) {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    line-height: 1.25;
    color: var(--parchment);
  }

  .viz-grid :global(.viz-desc) {
    font-size: var(--text-sm);
    color: var(--teak);
    line-height: var(--leading-relaxed);
    margin-top: auto;
  }

  @media (max-width: 30em) {
    .listing-wrap {
      padding-block: 1.5rem 2rem;
    }

    .listing-wrap :global(.container) {
      padding-inline: 0.5rem;
    }

    h1 {
      font-size: var(--text-2xl);
      margin-bottom: 0.25rem;
    }

    .tagline {
      font-size: var(--text-sm);
      margin-bottom: 1.5rem;
    }

    .viz-grid {
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
      padding: 0;
      margin: 0;
    }

    .viz-grid {
      gap: 0.375rem;
    }

    .viz-grid :global(.viz-card) {
      padding: 0.5rem 0.625rem;
      gap: 0.125rem;
      border-radius: 0.375rem;
    }

    .viz-grid :global(.viz-category) {
      font-size: 0.5rem;
      letter-spacing: 0.08em;
      margin-bottom: 0;
    }

    .viz-grid :global(.viz-title) {
      font-size: 1.1rem;
      line-height: 1.2;
    }

    .viz-grid :global(.viz-desc) {
      font-size: var(--text-sm);
      line-height: 1.4;
    }
  }
</style>

<script is:inline>
(function() {
  function equalizeCards() {
    var cards = document.querySelectorAll('.viz-card');
    if (!cards.length) return;

    // Reset all heights
    cards.forEach(function(c) {
      c.style.minHeight = '';
      var title = c.querySelector('.viz-title');
      if (title) title.style.minHeight = '';
    });

    // Force reflow so natural heights are recalculated
    void document.body.offsetHeight;

    // Group by row using a tolerance of 5px for sub-pixel differences
    var rows = [];
    var lastTop = -999;
    var currentRow = [];
    var sorted = Array.from(cards).sort(function(a, b) {
      return a.getBoundingClientRect().top - b.getBoundingClientRect().top;
    });

    sorted.forEach(function(card) {
      var top = card.getBoundingClientRect().top;
      if (Math.abs(top - lastTop) > 5) {
        if (currentRow.length) rows.push(currentRow);
        currentRow = [];
        lastTop = top;
      }
      currentRow.push(card);
    });
    if (currentRow.length) rows.push(currentRow);

    rows.forEach(function(row) {
      // Only equalize if more than one card in the row
      if (row.length < 2) return;

      var maxCard = 0;
      var maxTitle = 0;

      row.forEach(function(card) {
        if (card.offsetHeight > maxCard) maxCard = card.offsetHeight;
        var title = card.querySelector('.viz-title');
        if (title && title.offsetHeight > maxTitle) maxTitle = title.offsetHeight;
      });

      row.forEach(function(card) {
        card.style.minHeight = (maxCard / 16) + 'rem';
        var title = card.querySelector('.viz-title');
        if (title) title.style.minHeight = (maxTitle / 16) + 'rem';
      });
    });
  }

  function init() {
    if (!document.querySelector('.viz-grid')) return;
    equalizeCards();
    window.addEventListener('resize', equalizeCards);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
})();
</script>
