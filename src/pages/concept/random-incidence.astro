---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TabNav from '../../components/TabNav.astro';
import { loadGlobal, loadPage } from '../../lib/content';

const global = loadGlobal();
const { meta, content } = loadPage('random-incidence');
const c = content as {
  heading: string;
  eyebrow: string;
  subtitle: string;
};

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: c.heading,
  description: meta.description,
  url: global.url + '/concept/random-incidence',
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
>

  <section class="viz-wrap">
    <div class="viz-container" x-data="randomIncidence">

      <p class="eyebrow">{c.eyebrow}</p>
      <h1>{c.heading}</h1>
      <p class="subtitle">{c.subtitle}</p>

      <div class="card">
        <div class="card-header">
          <p class="card-label">Arrival process</p>
          <div class="controls" x-on:change="simulate()">
            <TabNav
              modelField="dist"
              options={[
                { value: 'mixed', label: 'Mixed gaps' },
                { value: 'uniform', label: 'Uniform gaps' },
                { value: 'exponential', label: 'Exponential' },
              ]}
            />
          </div>
        </div>

        <canvas id="ri-timeline" class="timeline-canvas"></canvas>

        <div class="stats-row">
          <span class="stat" x-text="'true avg gap: ' + trueAvg + 's'"></span>
          <span class="stat observed" x-text="'observed avg: ' + obsAvg + 's'"></span>
          <button class="button-viz" x-on:click="simulate()">Resample</button>
        </div>
      </div>

      <div class="card">
        <p class="card-label">True vs observed interval distribution (500 random pins)</p>
        <canvas id="ri-histogram"></canvas>
      </div>

      <div class="insight">
        <p class="card-label">The paradox</p>
        <ul>
          <li><strong>Longer intervals take up more time</strong>, so a random observer is more likely to land in one.</li>
          <li><strong>The observed average is always larger</strong> than the true average interval length.</li>
          <li><strong>For Poisson processes</strong>, 𝔼[observed] = 2/λ while 𝔼[true] = 1/λ. Exactly double.</li>
          <li><strong>This applies everywhere:</strong> bus wait times, class sizes, packet interarrival. The "inspection paradox."</li>
        </ul>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .card-header {
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .card-label {
    margin-bottom: 0.5rem;
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .timeline-canvas {
    display: block;
    width: 100%;
    height: 5.5rem;
  }

  .stats-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .stat {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--teak);
  }

  .stat.observed {
    color: var(--sienna);
  }

  .button-viz {
    margin-left: auto;
  }
</style>
