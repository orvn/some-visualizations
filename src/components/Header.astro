---
import Nav from './Nav.astro';
import { loadGlobal } from '../lib/content';

const { name } = loadGlobal();
---

<header class="site-header" role="banner">
  <div class="container header-inner">
    <a href="/" class="site-logo" aria-label={`${name} — go to homepage`}>
      {name}
    </a>
    <Nav />
  </div>
</header>

<style>
  .site-header {
    position: relative;
    height: var(--header-height);
    background-color: var(--graphite);
    border-bottom: 0.0625rem solid var(--bronze);
    z-index: var(--z-header);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .site-logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--parchment);
    text-decoration: none;
    letter-spacing: -0.02em;
    transition: color var(--transition-fast);
  }

  .site-logo:hover {
    color: var(--colonial);
  }
</style>
