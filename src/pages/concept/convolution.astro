---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TabNav from '../../components/TabNav.astro';
import { loadGlobal, loadPage } from '../../lib/content';

const global = loadGlobal();
const { meta, content } = loadPage('convolution');
const c = content as {
  heading: string;
  eyebrow: string;
  subtitle: string;
};

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: c.heading,
  description: meta.description,
  url: global.url + '/concept/convolution',
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
>

  <section class="viz-wrap">
    <div class="viz-container" x-data="convolutionViz">

      <p class="eyebrow">{c.eyebrow}</p>
      <h1>{c.heading}</h1>
      <p class="subtitle">{c.subtitle}</p>

      <div class="card">
        <div class="card-controls" x-on:change="stop(); updateStatic()">
          <TabNav
            modelField="pair"
            options={[
              { value: 'uniform-uniform', label: 'Unif + Unif' },
              { value: 'uniform-exponential', label: 'Unif + Exp' },
              { value: 'triangle-uniform', label: 'Tri + Unif' },
            ]}
          />
        </div>

        <p class="card-label">Flip and slide: f(x) and g(z−x)</p>
        <canvas id="conv-chart"></canvas>

        <div class="slider-row">
          <span class="slider-val" x-text="'z = ' + zDisplay"></span>
          <input type="range"
                 min="-2" max="4" step="0.02"
                 x-model="z"
                 x-on:input="stop(); updateStatic()"
                 x-bind:disabled="playing" />
          <button class="button-viz" x-on:click="playing ? stop() : play()" x-text="playing ? 'Stop' : 'Animate'"></button>
        </div>
      </div>

      <div class="card">
        <p class="card-label" x-text="'Result: ' + resultLabel">Result</p>
        <canvas id="conv-result"></canvas>
      </div>

      <div class="insight">
        <p class="card-label">How it works</p>
        <ul>
          <li><strong>f * g(z) = ∫ f(x)·g(z−x) dx</strong>. Flip g, slide it by z, multiply with f, and integrate the overlap.</li>
          <li><strong>Uniform + Uniform = Triangle.</strong> The overlap area grows linearly then shrinks, forming a triangle.</li>
          <li><strong>The green area</strong> in the top chart is the integrand at each position. Its total area equals the result value at that z.</li>
          <li><strong>Order doesn't matter:</strong> f * g = g * f. Convolution is commutative.</li>
        </ul>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .card-controls {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 0.75rem;
  }

  .card-label {
    margin-bottom: 0.5rem;
  }

  .slider-row {
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .slider-val {
    min-width: 4rem;
  }

  @media (max-width: 30em) {
    .slider-row {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.5rem;
    }

    .slider-val {
      min-width: auto;
      font-size: var(--text-sm);
    }

    .slider-row :global(.button-viz) {
      grid-column: 1 / -1;
      justify-self: end;
    }
  }
</style>
