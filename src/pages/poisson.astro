---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadGlobal, loadPage } from '../lib/content';

const global = loadGlobal();
const { meta, content } = loadPage('poisson');
const c = content as {
  heading: string;
  eyebrow: string;
  subtitle: string;
};

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: c.heading,
  description: meta.description,
  url: global.url + '/poisson',
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
>

  <section class="viz-wrap">
    <div class="viz-container" x-data="poissonProcess">

      <p class="eyebrow">{c.eyebrow}</p>
      <h1>{c.heading}</h1>
      <p class="subtitle">{c.subtitle}</p>

      <div class="card">
        <div class="card-header">
          <p class="card-label">Arrivals</p>
          <div class="controls">
            <div class="slider-group">
              <span class="slider-val" x-text="'λ = ' + parseFloat(lambda).toFixed(1)"></span>
              <input type="range" min="0.5" max="8" step="0.5"
                     x-model="lambda"
                     x-on:input="simulate()" />
            </div>
            <span class="resample-label" x-show="resampling" x-transition.opacity>resampling</span>
          </div>
        </div>

        <canvas id="poissonTimeline" class="timeline-canvas"></canvas>
        <p class="stat-line" x-text="info">&nbsp;</p>
      </div>

      <div class="card">
        <p class="card-label">Cumulative count N(t)</p>
        <canvas id="poissonStaircase"></canvas>
      </div>

      <div class="insight">
        <p class="card-label">Key properties</p>
        <ul>
          <li><strong>Interarrival times are exponential</strong> with rate λ, meaning they're memoryless.</li>
          <li><strong>N(t) ~ Poisson(λt)</strong>. The count in any interval of length t follows a Poisson distribution.</li>
          <li><strong>E[N(t)] = Var(N(t)) = λt</strong>. Expectation and variance are equal.</li>
          <li><strong>Disjoint intervals are independent.</strong> What happens in [0,5] tells you nothing about [5,10].</li>
        </ul>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .viz-wrap {
    padding-block: 2rem 4rem;
  }

  .viz-container {
    max-width: 54rem;
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .eyebrow {
    text-align: center;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--potters-clay);
    margin-bottom: 0.5rem;
  }

  h1 {
    text-align: center;
    font-size: var(--text-3xl);
    font-weight: normal;
    letter-spacing: var(--tracking-tight);
    margin-bottom: 0.5rem;
    color: var(--parchment);
  }

  .subtitle {
    text-align: center;
    color: var(--teak);
    font-size: var(--text-sm);
    margin-bottom: 1.75rem;
  }

  .card {
    background: var(--crow);
    border: 0.0625rem solid var(--bronze);
    border-radius: 0.75rem;
    padding: 1.25rem 1.25rem 0.875rem;
    margin-bottom: 1.25rem;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.875rem;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .card-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--potters-clay);
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .slider-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .slider-val {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: bold;
    color: var(--colonial);
    min-width: 3.5rem;
    white-space: nowrap;
  }

  input[type=range] {
    -webkit-appearance: none;
    appearance: none;
    width: 7rem;
    cursor: pointer;
    height: 0.5rem;
    background: transparent;
    padding: 0.75rem 0;
    margin: 0;
  }

  input[type=range]::-webkit-slider-runnable-track {
    height: 0.5rem;
    background: var(--bronze);
    border-radius: 0.25rem;
  }

  input[type=range]::-moz-range-track {
    height: 0.5rem;
    background: var(--bronze);
    border-radius: 0.25rem;
    border: none;
  }

  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 1.5rem;
    height: 1.5rem;
    background: var(--colonial);
    border-radius: 50%;
    border: none;
    margin-top: -0.5rem;
    cursor: pointer;
  }

  input[type=range]::-moz-range-thumb {
    width: 1.5rem;
    height: 1.5rem;
    background: var(--colonial);
    border-radius: 50%;
    border: none;
    cursor: pointer;
  }

  .resample-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--potters-clay);
    font-style: italic;
  }

  .timeline-canvas {
    display: block;
    width: 100%;
    height: 6.5rem;
  }

  canvas {
    display: block;
    width: 100% !important;
  }

  .stat-line {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--teak);
    margin-top: 0.5rem;
    min-height: 1.2em;
  }

  .insight {
    border-top: 0.0625rem solid var(--bronze);
    padding-top: 1.25rem;
  }

  .insight ul {
    color: var(--teak);
    font-size: var(--text-sm);
    line-height: 1.9;
    padding-left: 1.125rem;
  }

  .insight li strong {
    color: var(--parchment);
    font-weight: normal;
  }
</style>
