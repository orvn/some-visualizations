---
import BaseLayout from '../layouts/BaseLayout.astro';
import TabNav from '../components/TabNav.astro';
import { loadGlobal, loadPage } from '../lib/content';

const global = loadGlobal();
const { meta, content } = loadPage('clt');
const c = content as {
  heading: string;
  eyebrow: string;
  subtitle: string;
};

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: c.heading,
  description: meta.description,
  url: global.url + '/clt',
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
>

  <section class="viz-wrap">
    <div class="viz-container" x-data="cltViz">

      <p class="eyebrow">{c.eyebrow}</p>
      <h1>{c.heading}</h1>
      <p class="subtitle">{c.subtitle}</p>

      <div class="card">
        <div class="card-controls" x-on:change="run()">
          <div class="card-controls-top">
            <TabNav
              modelField="dist"
              options={[
                { value: 'uniform', label: 'Uniform' },
                { value: 'exponential', label: 'Exponential' },
                { value: 'bernoulli', label: 'Bernoulli' },
                { value: 'bimodal', label: 'Bimodal' },
              ]}
            />
          </div>
          <div class="param-row" x-bind:class="{ 'is-disabled': !hasParam }">
            <span class="param-label" x-text="paramLabel"></span>
            <input type="range"
                   min="0.05" max="0.95" step="0.05"
                   x-model="param"
                   x-on:input="run()"
                   x-bind:disabled="!hasParam" />
          </div>
        </div>

        <canvas id="clt-chart"></canvas>

        <div class="slider-row">
          <span class="slider-val" x-text="'n = ' + n"></span>
          <input type="range" min="1" max="100" step="1"
                 x-model="n"
                 x-on:input="run()" />
        </div>
      </div>

      <div class="insight">
        <p class="card-label">Key idea</p>
        <ul>
          <li><strong>Zₙ = (Sₙ - nμ) / (σ√n)</strong> standardizes the sum to zero mean and unit variance.</li>
          <li><strong>As n grows</strong>, the histogram of Zₙ converges to the standard normal N(0,1), shown in green.</li>
          <li><strong>This holds for any source distribution</strong> with finite mean and variance. Try switching between them.</li>
          <li><strong>Symmetric distributions converge faster</strong> than skewed ones. Compare Uniform (fast) vs Exponential (slower).</li>
        </ul>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .viz-wrap {
    padding-block: 2rem 4rem;
  }

  .viz-container {
    max-width: 54rem;
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .eyebrow {
    text-align: center;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--potters-clay);
    margin-bottom: 0.5rem;
  }

  h1 {
    text-align: center;
    font-size: var(--text-3xl);
    font-weight: normal;
    letter-spacing: var(--tracking-tight);
    margin-bottom: 0.5rem;
    color: var(--parchment);
  }

  .subtitle {
    text-align: center;
    color: var(--teak);
    font-size: var(--text-sm);
    margin-bottom: 1.75rem;
  }

  .card {
    background: var(--crow);
    border: 0.0625rem solid var(--bronze);
    border-radius: 0.75rem;
    padding: 1.25rem 1.25rem 0.875rem;
    margin-bottom: 1.25rem;
  }

  .card-controls {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.625rem;
    margin-bottom: 0.875rem;
  }

  .card-controls-top {
    display: flex;
    justify-content: flex-end;
  }

  .param-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: opacity var(--transition-fast);
  }

  .param-row.is-disabled {
    opacity: 0.25;
    pointer-events: none;
  }

  .param-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--teak);
    min-width: 4rem;
    white-space: nowrap;
  }

  .param-row input[type=range] {
    width: 7rem;
  }

  .card-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--potters-clay);
  }

  canvas {
    display: block;
    width: 100% !important;
  }

  .slider-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.875rem;
  }

  .slider-val {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: bold;
    color: var(--colonial);
    min-width: 4.5rem;
  }

  input[type=range] {
    -webkit-appearance: none;
    appearance: none;
    flex: 1;
    cursor: pointer;
    height: 0.5rem;
    background: transparent;
    padding: 0.75rem 0;
    margin: 0;
  }

  input[type=range]::-webkit-slider-runnable-track {
    height: 0.5rem;
    background: var(--bronze);
    border-radius: 0.25rem;
  }

  input[type=range]::-moz-range-track {
    height: 0.5rem;
    background: var(--bronze);
    border-radius: 0.25rem;
    border: none;
  }

  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 1.5rem;
    height: 1.5rem;
    background: var(--colonial);
    border-radius: 50%;
    border: none;
    margin-top: -0.5rem;
    cursor: pointer;
  }

  input[type=range]::-moz-range-thumb {
    width: 1.5rem;
    height: 1.5rem;
    background: var(--colonial);
    border-radius: 50%;
    border: none;
    cursor: pointer;
  }

  .insight {
    border-top: 0.0625rem solid var(--bronze);
    padding-top: 1.25rem;
  }

  .insight ul {
    color: var(--teak);
    font-size: var(--text-sm);
    line-height: 1.9;
    padding-left: 1.125rem;
  }

  .insight li strong {
    color: var(--parchment);
    font-weight: normal;
  }
</style>
