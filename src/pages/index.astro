---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadGlobal, loadPage } from '../lib/content';

const global = loadGlobal();
const { meta, content } = loadPage('home');
const c = content as {
  heading: string;
  tagline: string;
};

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: global.name,
  description: global.description,
  url: global.url,
};

const visualizations = [
  {
    title: 'Normal Distribution & Variance',
    description: 'Interactive visualization of normal distribution curves and how variance controls spread.',
    category: 'Statistics / Probability',
    href: '/normals',
  },
];
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
>

  <section class="listing-wrap">
    <div class="container">
      <h1>{c.heading}</h1>
      <p class="tagline">{c.tagline}</p>

      <ul class="viz-grid" role="list">
        {visualizations.map((viz) => (
          <li>
            <a href={viz.href} class="viz-card">
              <span class="viz-category">{viz.category}</span>
              <span class="viz-title">{viz.title}</span>
              <span class="viz-desc">{viz.description}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

</BaseLayout>

<style>
  .listing-wrap {
    padding-block: 3rem 4rem;
  }

  h1 {
    font-size: var(--text-3xl);
    font-weight: normal;
    color: var(--parchment);
    margin-bottom: 0.5rem;
  }

  .tagline {
    color: var(--teak);
    font-size: var(--text-base);
    margin-bottom: 3rem;
  }

  .viz-grid :global(li) {
    list-style: none;
  }

  .viz-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
    gap: 1.25rem;
  }

  .viz-grid :global(.viz-card) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    background: var(--crow);
    border: 0.0625rem solid var(--bronze);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: border-color var(--transition-fast), background-color var(--transition-fast);
  }

  .viz-grid :global(.viz-card:hover) {
    border-color: var(--potters-clay);
    background: var(--clinker);
  }

  .viz-grid :global(.viz-category) {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--potters-clay);
  }

  .viz-grid :global(.viz-title) {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--parchment);
  }

  .viz-grid :global(.viz-desc) {
    font-size: var(--text-sm);
    color: var(--teak);
    line-height: var(--leading-relaxed);
  }
</style>
