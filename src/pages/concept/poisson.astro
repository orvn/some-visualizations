---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadGlobal, loadPage } from '../../lib/content';

const global = loadGlobal();
const { meta, content } = loadPage('poisson');
const c = content as {
  heading: string;
  eyebrow: string;
  subtitle: string;
};

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: c.heading,
  description: meta.description,
  url: global.url + '/concept/poisson',
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
>

  <section class="viz-wrap">
    <div class="viz-container" x-data="poissonProcess">

      <p class="eyebrow">{c.eyebrow}</p>
      <h1>{c.heading}</h1>
      <p class="subtitle">{c.subtitle}</p>

      <div class="card">
        <div class="card-header">
          <p class="card-label">Arrivals</p>
          <div class="controls">
            <span class="resample-label" x-show="resampling" x-transition.opacity x-text="resampleText"></span>
            <div class="slider-group">
              <span class="slider-val" x-text="'λ = ' + parseFloat(lambda).toFixed(1)"></span>
              <input type="range" min="0.5" max="8" step="0.5"
                     x-model="lambda"
                     x-on:input="simulate()" />
            </div>
          </div>
        </div>

        <canvas id="poisson-timeline" class="timeline-canvas"></canvas>
        <p class="stat-line" x-html="info.replace(/  ·  /g, '<br class=stat-break>')">&nbsp;</p>
      </div>

      <div class="card">
        <p class="card-label">Cumulative count N(t)</p>
        <canvas id="poisson-staircase"></canvas>
      </div>

      <div class="insight">
        <p class="card-label">Key properties</p>
        <ul>
          <li><strong>Interarrival times are exponential</strong> with rate λ, meaning they're memoryless.</li>
          <li><strong>N(t) ~ Poisson(λt)</strong>. The count in any interval of length t follows a Poisson distribution.</li>
          <li><strong>𝔼[N(t)] = 𝕍(N(t)) = λt</strong>. Expectation and variance are equal.</li>
          <li><strong>Disjoint intervals are independent.</strong> What happens in [0,5] tells you nothing about [5,10].</li>
        </ul>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .card-header {
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .slider-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .slider-val {
    font-size: var(--text-xs);
    min-width: 3.5rem;
    white-space: nowrap;
  }

  input[type=range] {
    width: 7rem;
    flex: none;
  }

  .resample-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--potters-clay);
    font-style: italic;
    min-width: 7rem;
  }

  .timeline-canvas {
    display: block;
    width: 100%;
    height: 6.5rem;
  }

  .stat-line :global(.stat-break) {
    display: none;
  }

  @media (max-width: 30em) {
    .stat-line :global(.stat-break) {
      display: block;
    }
  }

  .stat-line {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--teak);
    margin-top: 0.5rem;
    min-height: 1.2em;
  }
</style>
