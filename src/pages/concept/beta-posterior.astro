---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadGlobal, loadPage } from '../../lib/content';

const global = loadGlobal();
const { meta, content } = loadPage('beta-posterior');
const c = content as {
  heading: string;
  eyebrow: string;
  subtitle: string;
};

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: c.heading,
  description: meta.description,
  url: global.url + '/concept/beta-posterior',
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
>

  <section class="viz-wrap">
    <div class="viz-container" x-data="bayesBeta">

      <p class="eyebrow">{c.eyebrow}</p>
      <h1>{c.heading}</h1>
      <p class="subtitle">{c.subtitle}</p>

      <div class="card">
        <div class="card-header">
          <p class="card-label">Posterior distribution</p>
          <div class="bias-controls">
            <div class="slider-row">
              <span class="slider-val" x-text="'bias: ' + parseFloat(bias).toFixed(2)"></span>
              <input
                type="range"
                min="0.01" max="0.99" step="0.01"
                x-model="bias"
                x-bind:disabled="running"
              />
            </div>
            <button
              class="button-viz"
              x-on:click="start()"
              x-bind:disabled="running"
              x-text="running ? 'Running...' : 'Start'"
            ></button>
          </div>
        </div>

        <div id="bayesChart" class="bayes-chart"></div>
        <p class="stat-line" x-text="info || 'set a bias and press start'">&nbsp;</p>
      </div>

      <div class="card toss-card" x-show="tosses.length > 0">
        <p class="card-label">Coin flips</p>
        <div id="bayesTosses" class="bayes-tosses"></div>
      </div>

    </div>
  </section>

  <script is:inline src="/js/d3.v3.min.js"></script>

</BaseLayout>

<style>
  .card-header {
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .bias-controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    min-width: 0;
  }

  @media (max-width: 30em) {
    .card-header {
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      gap: 0.5rem;
      align-items: center;
    }

    .card-header .card-label {
      grid-column: 1;
      grid-row: 1;
    }

    .card-header :global(.button-viz) {
      grid-column: 2;
      grid-row: 1;
    }

    .bias-controls {
      grid-column: 1 / -1;
      grid-row: 2;
      display: contents;
    }

    .bias-controls .slider-row {
      grid-column: 1 / -1;
      grid-row: 2;
    }
  }

  .slider-row {
    gap: 0.75rem;
    flex: 1;
  }

  .slider-val {
    font-size: var(--text-xs);
    min-width: 5rem;
    white-space: nowrap;
  }

  .button-viz:disabled {
    opacity: 0.5;
  }

  .bayes-chart :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }

  .bayes-chart :global(.axis path),
  .bayes-chart :global(.axis line) {
    fill: none;
    stroke: var(--potters-clay);
    stroke-width: 0.0625rem;
    shape-rendering: crispEdges;
  }

  .bayes-chart :global(.axis text) {
    fill: var(--potters-clay);
    font-size: 0.6875rem;
  }

  .bayes-chart :global(.trial) {
    fill: none;
    stroke: var(--colonial);
    stroke-width: 0.125rem;
  }

  .bayes-chart :global(.trial.prev) {
    fill: none;
    stroke: var(--sienna);
    opacity: 0.15;
    stroke-width: 0.125rem;
  }

  .bayes-chart :global(.trial.final) {
    stroke: var(--olivine);
    stroke-width: 0.1875rem;
    opacity: 1;
  }

  @media (max-width: 30em) {
    .bayes-chart :global(.axis text) {
      font-size: 1rem;
    }

    .bayes-chart :global(.axis path),
    .bayes-chart :global(.axis line) {
      stroke-width: 0.125rem;
    }

    .bayes-chart :global(.trial) {
      stroke-width: 0.25rem;
    }

    .bayes-chart :global(.trial.prev) {
      stroke-width: 0.1875rem;
    }

    .bayes-chart :global(.trial.final) {
      stroke-width: 0.3125rem;
    }
  }

  .stat-line {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--teak);
    margin-top: 0.5rem;
    min-height: 1.2em;
  }

  .toss-card {
    padding: 1.25rem;
  }

  .bayes-tosses :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }

  .bayes-tosses :global(.toss) {
    font-family: var(--font-mono);
    font-size: 1.125rem;
  }

  .bayes-tosses :global(.toss.heads) {
    fill: var(--sienna);
  }

  .bayes-tosses :global(.toss.tails) {
    fill: var(--olivine);
  }
</style>
