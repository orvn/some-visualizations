<style>
  .site-footer {
    margin-top: auto;
    background-color: var(--parchment);
  }

  .stepped-divider {
    display: block;
    width: 100%;
    height: auto;
    margin-bottom: -0.0625rem;
  }

  .footer-body ::selection {
    background-color: var(--clinker);
    color: var(--parchment);
  }

  .footer-body ::-moz-selection {
    background-color: var(--clinker);
    color: var(--parchment);
  }

  .footer-body {
    background-color: var(--parchment);
    padding-block: 2rem 1.5rem;
  }

  .footer-bins {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sienna);
    margin-bottom: 0.5rem;
    min-height: 1em;
  }

  .footer-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(3.5rem, 10vw, 6rem);
    max-width: 12ch;
    line-height: 1.05;
    color: var(--graphite);
    margin-bottom: 0.75rem;
  }

  .footer-tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    color: var(--graphite);
    opacity: 0.7;
    min-height: 1em;
  }

  .footer-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 0.0625rem solid var(--teak);
  }

  .footer-copy {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--potters-clay);
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .heart-icon {
    width: 0.875rem;
    height: 0.875rem;
    color: var(--sienna);
  }

  .footer-github {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--potters-clay);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-github:hover {
    color: var(--graphite);
  }

  .github-icon {
    width: 1.25rem;
    height: 1.25rem;
    margin-top: 0.125rem;
  }

  .footer-nav {
    display: flex;
    gap: 1.5rem;
  }

  .footer-nav a {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--graphite);
    text-decoration: underline;
    text-underline-offset: 0.15em;
    transition: color var(--transition-fast);
  }

  .footer-nav a:hover {
    color: var(--potters-clay);
  }
</style>

<script is:inline>
(function() {
  function initHistogram() {
    var svg = document.querySelector('.stepped-divider');
    if (!svg) return;
    var bars = svg.querySelectorAll('.hist-bars rect');
    if (!bars.length) return;

    var targets = [];
    bars.forEach(function(bar) {
      targets.push(parseFloat(bar.dataset.h));
    });

    function onScroll() {
      var rect = svg.getBoundingClientRect();
      var vh = window.innerHeight;

      // Progress: 0 when SVG top hits viewport bottom, 1 when SVG top reaches ~40% up the viewport
      var progress = (vh - rect.top) / (vh * 0.8);
      progress = Math.max(0, Math.min(1, progress));

      bars.forEach(function(bar, i) {
        var h = targets[i] * progress;
        bar.setAttribute('height', String(h));
        bar.setAttribute('y', String(150 - h));
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHistogram);
  } else {
    initHistogram();
  }
  document.addEventListener('astro:page-load', initHistogram);
})();
</script>
