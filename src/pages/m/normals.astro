---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TabNav from '../../components/TabNav.astro';
import { loadGlobal, loadPage } from '../../lib/content';

const global = loadGlobal();
const { meta, content } = loadPage('normals');
const c = content as {
  heading: string;
  eyebrow: string;
  subtitle: string;
};

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: c.heading,
  description: meta.description,
  url: global.url + '/m/normals',
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
>

  <section class="viz-wrap">
    <div class="viz-container" x-data="normalVariance">

      <p class="eyebrow">{c.eyebrow}</p>
      <h1>{c.heading}</h1>
      <p class="subtitle">{c.subtitle}</p>

      <div class="card">
        <div class="card-header">
          <p class="card-label" x-text="mode === 'a' ? 'Interactive' : 'Reference curves at fixed variances'"></p>
          <TabNav
            modelField="mode"
            options={[
              { value: 'a', label: 'Interactive' },
              { value: 'b', label: 'Reference' },
            ]}
          />
        </div>

        <canvas id="mainChart"></canvas>

        <div class="controls-wrap" x-bind:class="{ 'is-open': mode === 'a' }">
          <div class="controls-inner">
            <div class="slider-row">
              <span class="slider-val">σ² = <span x-text="targetVariance.toFixed(2)"></span></span>
              <input type="range" min="0.1" max="6" step="0.05"
                     x-bind:value="targetVariance"
                     x-on:input="setTarget($event.target.value)" />
              <span class="slider-sigma">σ = <span x-text="Math.sqrt(targetVariance).toFixed(3)"></span></span>
            </div>

            <p class="stat-line">
              Peak height = <span x-text="peak()"></span>
              &nbsp;·&nbsp;
              ≈68% of values fall within ±σ = <em x-text="'±' + Math.sqrt(displayedVariance).toFixed(3)"></em>
            </p>
          </div>
        </div>
      </div>

      <!-- Key intuition -->
      <div class="insight">
        <p class="card-label">Key intuition</p>
        <ul>
          <li><strong>Variance σ² &gt; 0 always.</strong> It's the average <em>squared</em> distance from the mean. Squaring eliminates negatives.</li>
          <li><strong>Larger σ²</strong> → flatter, wider bell → values more spread out, more uncertainty.</li>
          <li><strong>Smaller σ²</strong> → taller, narrower bell → values cluster tightly around the mean.</li>
          <li><strong>σ² = 0</strong> only if the variable is a constant. <strong>σ² &lt; 0</strong> is mathematically impossible.</li>
          <li>The area under every curve = 1. Total probability is always 100%, just differently shaped.</li>
        </ul>
      </div>

    </div>
  </section>


</BaseLayout>

<style>
  .viz-wrap {
    padding-block: 2rem 4rem;
  }

  .viz-container {
    max-width: 54rem;
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .eyebrow {
    text-align: center;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--potters-clay);
    margin-bottom: 0.5rem;
  }

  h1 {
    text-align: center;
    font-size: var(--text-3xl);
    font-weight: normal;
    letter-spacing: var(--tracking-tight);
    margin-bottom: 0.5rem;
    color: var(--parchment);
  }

  .subtitle {
    text-align: center;
    color: var(--teak);
    font-size: var(--text-sm);
    margin-bottom: 1.75rem;
  }

  .subtitle em {
    font-style: italic;
  }

  .card {
    background: var(--crow);
    border: 0.0625rem solid var(--bronze);
    border-radius: 0.75rem;
    padding: 1.25rem 1.25rem 0.875rem;
    margin-bottom: 1.25rem;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.875rem;
  }

  .card-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--potters-clay);
  }

  canvas {
    display: block;
    width: 100% !important;
  }

  .controls-wrap {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition: grid-template-rows var(--transition-base), opacity var(--transition-base);
    overflow: hidden;
  }

  .controls-wrap.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  .controls-inner {
    overflow: hidden;
  }

  .slider-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.875rem;
  }

  .slider-val {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: bold;
    color: var(--colonial);
    min-width: 6.25rem;
  }

  input[type=range] {
    -webkit-appearance: none;
    appearance: none;
    flex: 1;
    cursor: pointer;
    height: 0.5rem;
    background: transparent;
    padding: 0.75rem 0;
    margin: 0;
  }

  input[type=range]::-webkit-slider-runnable-track {
    height: 0.5rem;
    background: var(--bronze);
    border-radius: 0.25rem;
  }

  input[type=range]::-moz-range-track {
    height: 0.5rem;
    background: var(--bronze);
    border-radius: 0.25rem;
    border: none;
  }

  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 1.5rem;
    height: 1.5rem;
    background: var(--colonial);
    border-radius: 50%;
    border: none;
    margin-top: -0.5rem;
    cursor: pointer;
  }

  input[type=range]::-moz-range-thumb {
    width: 1.5rem;
    height: 1.5rem;
    background: var(--colonial);
    border-radius: 50%;
    border: none;
    cursor: pointer;
  }

  .slider-sigma {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--teak);
    min-width: 5rem;
    text-align: right;
  }

  .stat-line {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--potters-clay);
    margin-top: 0.5rem;
  }

  .stat-line span {
    color: var(--teak);
  }

  .stat-line em {
    color: var(--colonial);
    font-style: normal;
  }

  .insight {
    border-top: 0.0625rem solid var(--bronze);
    padding-top: 1.25rem;
  }

  .insight ul {
    color: var(--teak);
    font-size: var(--text-sm);
    line-height: 1.9;
    padding-left: 1.125rem;
  }

  .insight li strong {
    color: var(--parchment);
    font-weight: normal;
  }
</style>
