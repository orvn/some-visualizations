---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TabNav from '../../components/TabNav.astro';
import Switch from '../../components/Switch.astro';
import { loadGlobal, loadPage } from '../../lib/content';

const global = loadGlobal();
const { meta, content } = loadPage('bivariate-normals');
const c = content as {
  heading: string;
  eyebrow: string;
  subtitle: string;
};

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: c.heading,
  description: meta.description,
  url: global.url + '/concept/bivariate-normals',
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
>

  <section class="viz-wrap">
    <div class="viz-container" x-data="bivariateNormals">

      <p class="eyebrow">{c.eyebrow}</p>
      <h1>{c.heading}</h1>
      <p class="subtitle">{c.subtitle}</p>

      <div class="card">
        <div class="card-header" x-on:change="render()">
          <p class="card-label"><span class="label-upper">Joint PDF</span> f(x, y)</p>
          <TabNav
            modelField="mode"
            options={[
              { value: 'general', label: 'General' },
              { value: 'bivariate', label: 'Bivariate (ρ)' },
            ]}
          />
        </div>
        <canvas id="bn-surface" class="surface-canvas"></canvas>

        <div class="param-group" x-transition>
          <div class="slider-row">
            <span class="slider-val" x-text="'σₓ = ' + parseFloat(sigmaX).toFixed(1)"></span>
            <input type="range" min="0.5" max="3" step="0.1"
                   x-model="sigmaX"
                   x-on:input="render()" />
          </div>
          <div class="slider-row">
            <span class="slider-val" x-text="'σᵧ = ' + parseFloat(sigmaY).toFixed(1)"></span>
            <input type="range" min="0.5" max="3" step="0.1"
                   x-model="sigmaY"
                   x-on:input="render()" />
          </div>
        </div>

        <div class="rho-wrap" x-bind:class="{ 'is-open': mode === 'bivariate' }">
          <div class="rho-inner">
          <div class="slider-row">
            <span class="slider-val" x-text="'ρ = ' + parseFloat(rho).toFixed(2)"></span>
            <input type="range" min="-0.95" max="0.95" step="0.05"
                   x-model="rho"
                   x-on:input="render()" />
          </div>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <p class="card-label">Contour view with conditional slice</p>
          <span class="cond-info" x-text="condInfo"></span>
        </div>

        <div class="split-view">
          <div class="heatmap-wrap">
            <canvas id="bn-heatmap" class="heatmap-canvas"></canvas>
          </div>
          <div class="slice-col">
            <div class="slice-controls">
              <div class="overlay-toggles">
                <span x-on:change="render()"><Switch modelField="showContours" label="contours" /></span>
                <span x-on:change="render()"><Switch modelField="showAnnotations" label="labels" /></span>
              </div>
              <div class="slice-slider">
                <span class="slider-val slice-label" x-text="'slice y = ' + parseFloat(sliceY).toFixed(1)"></span>
                <input type="range" min="-3" max="3" step="0.1"
                       x-model="sliceY"
                       x-on:input="render()" />
              </div>
            </div>
            <canvas id="bn-slice"></canvas>
          </div>
        </div>
      </div>

      <div class="insight">
        <p class="card-label">Key ideas</p>
        <ul>
          <li><strong>General normals</strong> have axis-aligned elliptical contours. Circular when $\sigma_x = \sigma_y$, stretched when they differ.</li>
          <li><strong>Bivariate ($\rho \neq 0$)</strong> tilts the ellipse. The contours are no longer axis-aligned.</li>
          <li><strong>Slicing at y = c</strong> gives f(x|Y=c), a normal with shifted mean {"$\\rho(\\sigma_x/\\sigma_y)c$"} and reduced variance {"$\\sigma_x^2(1-\\rho^2)$"}.</li>
        </ul>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .eyebrow {
    text-transform: none;
  }

  .label-upper {
    text-transform: uppercase;
  }

  .card-header {
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .card-label {
    text-transform: none;
    margin-bottom: 0.5rem;
  }

  .slice-col {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .slice-controls {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .overlay-toggles {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: flex-end;
  }

  .slice-slider {
    display: flex;
    flex-direction: row-reverse;
    align-items: center;
    gap: 0.75rem;
  }

  .slice-slider input[type=range] {
    max-width: 8rem;
  }

  .slice-label {
    font-size: var(--text-xs) !important;
    font-weight: normal !important;
    min-width: 6rem;
  }

  .cond-info {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--sienna);
  }

  .surface-canvas {
    display: block;
    width: 100%;
    height: 18rem;
    margin-bottom: 0.5rem;
  }

  .param-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-top: 0.5rem;
  }

  .rho-wrap {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition: grid-template-rows var(--transition-base), opacity var(--transition-base);
    overflow: hidden;
  }

  .rho-wrap.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  .rho-inner {
    overflow: hidden;
  }

  .split-view {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    align-items: end;
  }

  .heatmap-canvas {
    display: block;
    width: 100%;
    height: 24rem;
  }

  @media (max-width: 30em) {
    .surface-canvas {
      height: 14rem;
      margin-top: -2rem;
    }

    .split-view {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .heatmap-canvas {
      height: 18rem;
    }
  }

  .slice-wrap canvas {
    display: block;
    width: 100% !important;
  }

  .slider-row {
    margin-top: 0.5rem;
  }

  .slider-val {
    font-size: var(--text-sm);
    min-width: 5.5rem;
    white-space: nowrap;
  }
</style>
