---
import BaseLayout from '../layouts/BaseLayout.astro';
import TabNav from '../components/TabNav.astro';
import { loadGlobal, loadPage } from '../lib/content';

const global = loadGlobal();
const { meta, content } = loadPage('random-incidence');
const c = content as {
  heading: string;
  eyebrow: string;
  subtitle: string;
};

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: c.heading,
  description: meta.description,
  url: global.url + '/random-incidence',
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
>

  <section class="viz-wrap">
    <div class="viz-container" x-data="randomIncidence">

      <p class="eyebrow">{c.eyebrow}</p>
      <h1>{c.heading}</h1>
      <p class="subtitle">{c.subtitle}</p>

      <div class="card">
        <div class="card-header">
          <p class="card-label">Arrival process</p>
          <div class="controls" x-on:change="simulate()">
            <TabNav
              modelField="dist"
              options={[
                { value: 'mixed', label: 'Mixed gaps' },
                { value: 'uniform', label: 'Uniform gaps' },
                { value: 'exponential', label: 'Exponential' },
              ]}
            />
          </div>
        </div>

        <canvas id="ri-timeline" class="timeline-canvas"></canvas>

        <div class="stats-row">
          <span class="stat" x-text="'true avg gap: ' + trueAvg + 's'"></span>
          <span class="stat observed" x-text="'observed avg: ' + obsAvg + 's'"></span>
          <button class="btn-resample" x-on:click="simulate()">Resample</button>
        </div>
      </div>

      <div class="card">
        <p class="card-label">True vs observed interval distribution (500 random pins)</p>
        <canvas id="ri-histogram"></canvas>
      </div>

      <div class="insight">
        <p class="card-label">The paradox</p>
        <ul>
          <li><strong>Longer intervals take up more time</strong>, so a random observer is more likely to land in one.</li>
          <li><strong>The observed average is always larger</strong> than the true average interval length.</li>
          <li><strong>For Poisson processes</strong>, 𝔼[observed] = 2/λ while 𝔼[true] = 1/λ. Exactly double.</li>
          <li><strong>This applies everywhere:</strong> bus wait times, class sizes, packet interarrival. The "inspection paradox."</li>
        </ul>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .viz-wrap {
    padding-block: 2rem 4rem;
  }

  .viz-container {
    max-width: 54rem;
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .eyebrow {
    text-align: center;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--potters-clay);
    margin-bottom: 0.5rem;
  }

  h1 {
    text-align: center;
    font-size: var(--text-3xl);
    font-weight: normal;
    letter-spacing: var(--tracking-tight);
    margin-bottom: 0.5rem;
    color: var(--parchment);
  }

  .subtitle {
    text-align: center;
    color: var(--teak);
    font-size: var(--text-sm);
    margin-bottom: 1.75rem;
  }

  .card {
    background: var(--crow);
    border: 0.0625rem solid var(--bronze);
    border-radius: 0.75rem;
    padding: 1.25rem 1.25rem 0.875rem;
    margin-bottom: 1.25rem;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.875rem;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .card-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--potters-clay);
    margin-bottom: 0.5rem;
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .timeline-canvas {
    display: block;
    width: 100%;
    height: 5.5rem;
  }

  canvas {
    display: block;
    width: 100% !important;
  }

  .stats-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .stat {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--teak);
  }

  .stat.observed {
    color: var(--sienna);
  }

  .btn-resample {
    margin-left: auto;
    padding: 0.375rem 1rem;
    background: var(--bronze);
    border: 0.0625rem solid var(--potters-clay);
    border-radius: 0.375rem;
    color: var(--parchment);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background-color var(--transition-fast);
  }

  .btn-resample:hover {
    background: var(--potters-clay);
  }

  .insight {
    border-top: 0.0625rem solid var(--bronze);
    padding-top: 1.25rem;
  }

  .insight ul {
    color: var(--teak);
    font-size: var(--text-sm);
    line-height: 1.9;
    padding-left: 1.125rem;
  }

  .insight li strong {
    color: var(--parchment);
    font-weight: normal;
  }
</style>
