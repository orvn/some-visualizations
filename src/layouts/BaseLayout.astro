---
import { ClientRouter } from 'astro:transitions';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import '../styles/common.css';

interface Props {
  /** Page-specific title. Omit on the home page to render just the site name. */
  title?: string;
  description?: string;
  ogImage?: string;
  /** Prevents indexing — use on 404, thank-you pages, etc. */
  noindex?: boolean;
  /**
   * JSON-LD structured data object. Serialised into a <script type="application/ld+json">.
   * Should be developer-supplied data only — never pass raw user input here.
   */
  jsonLD?: Record<string, unknown>;
}

const {
  title,
  description,
  ogImage,
  noindex = false,
  jsonLD,
} = Astro.props;

// Build the canonical URL. Requires `site` to be set in astro.config.mjs.
const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      noindex={noindex}
      canonicalURL={canonicalURL}
    />

    <!-- JSON-LD structured data -->
    {jsonLD && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLD)} />
    )}

    <!-- Client-side routing with animated page transitions (Astro 6) -->
    <ClientRouter />

    <link rel="apple-touch-icon" sizes="57x57" href="/apple-icon-57x57.png" />
    <link rel="apple-touch-icon" sizes="60x60" href="/apple-icon-60x60.png" />
    <link rel="apple-touch-icon" sizes="72x72" href="/apple-icon-72x72.png" />
    <link rel="apple-touch-icon" sizes="76x76" href="/apple-icon-76x76.png" />
    <link rel="apple-touch-icon" sizes="114x114" href="/apple-icon-114x114.png" />
    <link rel="apple-touch-icon" sizes="120x120" href="/apple-icon-120x120.png" />
    <link rel="apple-touch-icon" sizes="144x144" href="/apple-icon-144x144.png" />
    <link rel="apple-touch-icon" sizes="152x152" href="/apple-icon-152x152.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-icon-180x180.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/android-icon-192x192.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="msapplication-TileColor" content="#1a0c06" />
    <meta name="msapplication-TileImage" content="/ms-icon-144x144.png" />
    <meta name="theme-color" content="#1a0c06" />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>

  <body>
    <!-- Skip-to-content — first focusable element, visible on keyboard focus -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <Header />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <Footer />

    <script>
      document.addEventListener("click", (e) => {
        if (window.matchMedia("(hover: hover)").matches) return;

        const target = e.target as HTMLElement;
        const tooltip = target.closest(".tooltip-soon")
          || target.querySelector(":scope > .tooltip-soon")
          || (target.parentElement?.querySelector(":scope > .tooltip-soon"));

        document.querySelectorAll(".tooltip-soon.is-visible").forEach((el) => {
          if (el !== tooltip) el.classList.remove("is-visible");
        });

        if (tooltip) {
          tooltip.classList.toggle("is-visible");
        }
      });
    </script>
  </body>
</html>
