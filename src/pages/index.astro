---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadGlobal, loadPage } from '../lib/content';

const global = loadGlobal();
const { meta, content } = loadPage('home');
const c = content as {
  heading: string;
  eyebrow: string;
  subtitle: string;
};

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: global.name,
  description: global.description,
  url: global.url,
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
>

  <section class="viz-wrap">
    <div class="container" x-data="normalVariance()" x-init="init()">

      <p class="eyebrow">{c.eyebrow}</p>
      <h1>{c.heading}</h1>
      <p class="subtitle">{c.subtitle}</p>

      <!-- Reference chart -->
      <div class="card">
        <p class="card-label">Reference curves at fixed variances</p>
        <canvas id="refChart" height="240"></canvas>
      </div>

      <!-- Interactive animated chart -->
      <div class="card">
        <p class="card-label">Interactive — animated curve</p>

        <div class="slider-row">
          <span class="slider-val">σ² = <span x-text="targetVariance.toFixed(2)"></span></span>
          <input type="range" min="0.1" max="6" step="0.05"
                 :value="targetVariance"
                 @input="setTarget($event.target.value)" />
          <span class="slider-sigma">σ = <span x-text="Math.sqrt(targetVariance).toFixed(3)"></span></span>
        </div>

        <canvas id="liveChart" height="220"></canvas>

        <p class="stat-line">
          Peak height = <span x-text="peak()"></span>
          &nbsp;·&nbsp;
          ≈68% of values fall within ±σ = <em x-text="'±' + Math.sqrt(displayedVariance).toFixed(3)"></em>
        </p>
      </div>

      <!-- Key intuition -->
      <div class="insight">
        <p class="card-label">Key intuition</p>
        <ul>
          <li><strong>Variance σ² &gt; 0 always</strong> — it's the average <em>squared</em> distance from the mean. Squaring eliminates negatives.</li>
          <li><strong>Larger σ²</strong> → flatter, wider bell → values more spread out, more uncertainty.</li>
          <li><strong>Smaller σ²</strong> → taller, narrower bell → values cluster tightly around the mean.</li>
          <li><strong>σ² = 0</strong> only if the variable is a constant. <strong>σ² &lt; 0</strong> is mathematically impossible.</li>
          <li>The area under every curve = 1 — total probability is always 100%, just differently shaped.</li>
        </ul>
      </div>

    </div>
  </section>

</BaseLayout>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>

<script is:inline>
  var MEAN = 0;
  var X_VALS = [];
  for (var x = -6; x <= 6; x += 0.12) X_VALS.push(parseFloat(x.toFixed(2)));

  function pdf(x, variance) {
    var s = Math.sqrt(variance);
    return (1 / (s * Math.sqrt(2 * Math.PI))) * Math.exp(-0.5 * Math.pow((x - MEAN) / s, 2));
  }

  function makeScriptableGrad(hex, a0, a1) {
    a0 = a0 || 0.5;
    a1 = a1 || 0.01;
    var r = parseInt(hex.slice(1,3),16);
    var g = parseInt(hex.slice(3,5),16);
    var b = parseInt(hex.slice(5,7),16);
    var cached = null;
    return function(context) {
      var chart = context.chart;
      var ctx = chart.ctx;
      var chartArea = chart.chartArea;
      if (!chartArea) return 'rgba(' + r + ',' + g + ',' + b + ',0)';
      var top = chartArea.top;
      var bottom = chartArea.bottom;
      if (!cached || cached.top !== top || cached.bottom !== bottom) {
        var gr = ctx.createLinearGradient(0, top, 0, bottom);
        gr.addColorStop(0, 'rgba(' + r + ',' + g + ',' + b + ',' + a0 + ')');
        gr.addColorStop(1, 'rgba(' + r + ',' + g + ',' + b + ',' + a1 + ')');
        cached = { top: top, bottom: bottom, gr: gr };
      }
      return cached.gr;
    };
  }

  var BASE_OPTIONS = {
    animation: false,
    responsive: true,
    maintainAspectRatio: true,
    plugins: {
      legend: { display: true, labels: { color: '#b89470', font: { size: 12 } } },
      tooltip: {
        backgroundColor: '#2e1508',
        borderColor: '#3a1a0a',
        borderWidth: 1,
        titleColor: '#7a5a3a',
        bodyColor: '#f0d8a8',
      }
    },
    scales: {
      x: {
        type: 'linear', min: -6, max: 6,
        ticks: { color: '#7a5a3a', maxTicksLimit: 13 },
        grid: { color: '#2e1508' },
        border: { color: '#3a1a0a' },
        title: { display: true, text: 'x', color: '#7a5a3a' }
      },
      y: {
        min: 0, max: 0.85,
        ticks: { color: '#7a5a3a' },
        grid: { color: '#2e1508' },
        border: { color: '#3a1a0a' },
        title: { display: true, text: 'P(x)', color: '#7a5a3a' }
      }
    }
  };

  function normalVariance() {
    var liveChart = null;
    var animFrame = null;
    var currentVal = 1;

    function buildRefChart() {
      var existing = Chart.getChart('refChart');
      if (existing) existing.destroy();
      var ctx = document.getElementById('refChart').getContext('2d');
      var refs = [
        { v: 0.25, label: 'σ²=0.25  tight',   color: '#f07858' },
        { v: 1,    label: 'σ²=1  standard',    color: '#e8a050' },
        { v: 4,    label: 'σ²=4  wide',        color: '#90b878' },
      ];
      new Chart(ctx, {
        type: 'line',
        data: {
          labels: X_VALS,
          datasets: refs.map(function(r) {
            return {
              label: r.label,
              data: X_VALS.map(function(x) { return pdf(x, r.v); }),
              borderColor: r.color,
              borderWidth: 2,
              backgroundColor: makeScriptableGrad(r.color, 0.5, 0.01),
              fill: true, pointRadius: 0, tension: 0.4,
            };
          })
        },
        options: Object.assign({}, BASE_OPTIONS, {
          plugins: Object.assign({}, BASE_OPTIONS.plugins, {
            legend: { display: true, labels: { color: '#b89470', font: { size: 12 }, boxWidth: 12 } }
          })
        })
      });
    }

    function buildLiveChart(initVariance) {
      var existing = Chart.getChart('liveChart');
      if (existing) existing.destroy();
      var ctx = document.getElementById('liveChart').getContext('2d');
      liveChart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: X_VALS,
          datasets: [{
            label: 'your distribution',
            data: X_VALS.map(function(x) { return pdf(x, initVariance); }),
            borderColor: '#f0d8a8', borderWidth: 3,
            backgroundColor: makeScriptableGrad('#f0d8a8', 0.55, 0.01),
            fill: true, pointRadius: 0, tension: 0.4,
          }]
        },
        options: Object.assign({}, BASE_OPTIONS, {
          plugins: Object.assign({}, BASE_OPTIONS.plugins, { legend: { display: false } })
        })
      });
    }

    function updateLiveChart(variance) {
      if (!liveChart) return;
      liveChart.data.datasets[0].data = X_VALS.map(function(x) { return pdf(x, variance); });
      liveChart.update('none');
    }

    return {
      targetVariance: 1,
      displayedVariance: 1,

      init: function() {
        currentVal = this.targetVariance;
        buildRefChart();
        buildLiveChart(this.displayedVariance);
      },

      setTarget: function(val) {
        this.targetVariance = parseFloat(val);
        if (animFrame) cancelAnimationFrame(animFrame);
        var self = this;
        var SPEED = 0.10;
        var step = function() {
          var diff = self.targetVariance - currentVal;
          if (Math.abs(diff) < 0.0005) {
            currentVal = self.targetVariance;
            self.displayedVariance = self.targetVariance;
            updateLiveChart(self.displayedVariance);
            animFrame = null;
            return;
          }
          currentVal += diff * SPEED;
          self.displayedVariance = currentVal;
          updateLiveChart(self.displayedVariance);
          animFrame = requestAnimationFrame(step);
        };
        animFrame = requestAnimationFrame(step);
      },

      peak: function() {
        return pdf(MEAN, this.displayedVariance).toFixed(4);
      },
    };
  }
</script>

<style>
  .viz-wrap {
    padding-block: 2rem 4rem;
  }

  .eyebrow {
    text-align: center;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--potters-clay);
    margin-bottom: 0.5rem;
  }

  h1 {
    text-align: center;
    font-size: var(--text-3xl);
    font-weight: normal;
    letter-spacing: var(--tracking-tight);
    margin-bottom: 0.5rem;
    color: var(--parchment);
  }

  .subtitle {
    text-align: center;
    color: var(--teak);
    font-size: var(--text-sm);
    margin-bottom: 1.75rem;
  }

  .subtitle em {
    font-style: italic;
  }

  .card {
    background: var(--crow);
    border: 0.0625rem solid var(--bronze);
    border-radius: 0.75rem;
    padding: 1.25rem 1.25rem 0.875rem;
    margin-bottom: 1.25rem;
  }

  .card-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--potters-clay);
    margin-bottom: 0.875rem;
  }

  canvas {
    display: block;
    width: 100% !important;
  }

  .slider-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.875rem;
  }

  .slider-val {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: bold;
    color: var(--colonial);
    min-width: 6.25rem;
  }

  input[type=range] {
    flex: 1;
    accent-color: var(--colonial);
    cursor: pointer;
    height: 0.25rem;
  }

  .slider-sigma {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--teak);
    min-width: 5rem;
    text-align: right;
  }

  .stat-line {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--potters-clay);
    margin-top: 0.5rem;
  }

  .stat-line span {
    color: var(--teak);
  }

  .stat-line em {
    color: var(--colonial);
    font-style: normal;
  }

  .insight {
    border-top: 0.0625rem solid var(--bronze);
    padding-top: 1.25rem;
  }

  .insight ul {
    color: var(--teak);
    font-size: var(--text-sm);
    line-height: 1.9;
    padding-left: 1.125rem;
  }

  .insight li strong {
    color: var(--parchment);
    font-weight: normal;
  }
</style>
