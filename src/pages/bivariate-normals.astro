---
import BaseLayout from '../layouts/BaseLayout.astro';
import TabNav from '../components/TabNav.astro';
import Switch from '../components/Switch.astro';
import { loadGlobal, loadPage } from '../lib/content';

const global = loadGlobal();
const { meta, content } = loadPage('bivariate-normals');
const c = content as {
  heading: string;
  eyebrow: string;
  subtitle: string;
};

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: c.heading,
  description: meta.description,
  url: global.url + '/bivariate-normals',
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
>

  <section class="viz-wrap">
    <div class="viz-container" x-data="bivariateNormals">

      <p class="eyebrow">{c.eyebrow}</p>
      <h1>{c.heading}</h1>
      <p class="subtitle">{c.subtitle}</p>

      <div class="card">
        <div class="card-header" x-on:change="render()">
          <p class="card-label"><span class="label-upper">Joint PDF</span> f(x, y)</p>
          <TabNav
            modelField="mode"
            options={[
              { value: 'general', label: 'General' },
              { value: 'bivariate', label: 'Bivariate (ρ)' },
            ]}
          />
        </div>
        <canvas id="bn-surface" class="surface-canvas"></canvas>

        <div class="param-group" x-transition>
          <div class="slider-row">
            <span class="slider-val" x-text="'σₓ = ' + parseFloat(sigmaX).toFixed(1)"></span>
            <input type="range" min="0.5" max="3" step="0.1"
                   x-model="sigmaX"
                   x-on:input="render()" />
          </div>
          <div class="slider-row">
            <span class="slider-val" x-text="'σᵧ = ' + parseFloat(sigmaY).toFixed(1)"></span>
            <input type="range" min="0.5" max="3" step="0.1"
                   x-model="sigmaY"
                   x-on:input="render()" />
          </div>
        </div>

        <div class="rho-wrap" x-bind:class="{ 'is-open': mode === 'bivariate' }">
          <div class="rho-inner">
          <div class="slider-row">
            <span class="slider-val" x-text="'ρ = ' + parseFloat(rho).toFixed(2)"></span>
            <input type="range" min="-0.95" max="0.95" step="0.05"
                   x-model="rho"
                   x-on:input="render()" />
          </div>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <p class="card-label">Contour view with conditional slice</p>
          <span class="cond-info" x-text="condInfo"></span>
        </div>

        <div class="split-view">
          <div class="heatmap-wrap">
            <canvas id="bn-heatmap" class="heatmap-canvas"></canvas>
          </div>
          <div class="slice-col">
            <div class="slice-controls">
              <div class="overlay-toggles">
                <span x-on:change="render()"><Switch modelField="showContours" label="contours" /></span>
                <span x-on:change="render()"><Switch modelField="showAnnotations" label="labels" /></span>
              </div>
              <div class="slice-slider">
                <span class="slider-val slice-label" x-text="'slice y = ' + parseFloat(sliceY).toFixed(1)"></span>
                <input type="range" min="-3" max="3" step="0.1"
                       x-model="sliceY"
                       x-on:input="render()" />
              </div>
            </div>
            <canvas id="bn-slice"></canvas>
          </div>
        </div>
      </div>

      <div class="insight">
        <p class="card-label">Key ideas</p>
        <ul>
          <li><strong>General normals</strong> have axis-aligned elliptical contours. Circular when σₓ = σᵧ, stretched when they differ.</li>
          <li><strong>Bivariate (ρ ≠ 0)</strong> tilts the ellipse. The contours are no longer axis-aligned.</li>
          <li><strong>Slicing at y = c</strong> gives f(x|Y=c), a normal with shifted mean ρ(σₓ/σᵧ)c and reduced variance σₓ²(1−ρ²).</li>
        </ul>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .viz-wrap {
    padding-block: 2rem 4rem;
  }

  .viz-container {
    max-width: 54rem;
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .eyebrow {
    text-align: center;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: none;
    color: var(--potters-clay);
    margin-bottom: 0.5rem;
  }

  h1 {
    text-align: center;
    font-size: var(--text-3xl);
    font-weight: normal;
    letter-spacing: var(--tracking-tight);
    margin-bottom: 0.5rem;
    color: var(--parchment);
  }

  .subtitle {
    text-align: center;
    color: var(--teak);
    font-size: var(--text-sm);
    margin-bottom: 1.75rem;
  }

  .card {
    background: var(--crow);
    border: 0.0625rem solid var(--bronze);
    border-radius: 0.75rem;
    padding: 1.25rem 1.25rem 0.875rem;
    margin-bottom: 1.25rem;
  }

  .label-upper {
    text-transform: uppercase;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .card-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: none;
    color: var(--potters-clay);
    margin-bottom: 0.5rem;
  }

  .slice-col {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .slice-controls {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .overlay-toggles {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: flex-end;
  }

  .slice-slider {
    display: flex;
    flex-direction: row-reverse;
    align-items: center;
    gap: 0.75rem;
  }

  .slice-slider input[type=range] {
    max-width: 8rem;
  }

  .slice-label {
    font-size: var(--text-xs) !important;
    font-weight: normal !important;
    min-width: 6rem;
  }

  .cond-info {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--sienna);
  }

  .surface-canvas {
    display: block;
    width: 100%;
    height: 18rem;
    margin-bottom: 0.5rem;
  }

  .param-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-top: 0.5rem;
  }

  .rho-wrap {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition: grid-template-rows var(--transition-base), opacity var(--transition-base);
    overflow: hidden;
  }

  .rho-wrap.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  .rho-inner {
    overflow: hidden;
  }

  .split-view {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    align-items: end;
  }

  .heatmap-canvas {
    display: block;
    width: 100%;
    height: 24rem;
  }

  .slice-wrap canvas {
    display: block;
    width: 100% !important;
  }

  .slider-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .slider-val {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: bold;
    color: var(--colonial);
    min-width: 5.5rem;
    white-space: nowrap;
  }

  input[type=range] {
    -webkit-appearance: none;
    appearance: none;
    flex: 1;
    cursor: pointer;
    height: 0.5rem;
    background: transparent;
    padding: 0.75rem 0;
    margin: 0;
  }

  input[type=range]::-webkit-slider-runnable-track {
    height: 0.5rem;
    background: var(--bronze);
    border-radius: 0.25rem;
  }

  input[type=range]::-moz-range-track {
    height: 0.5rem;
    background: var(--bronze);
    border-radius: 0.25rem;
    border: none;
  }

  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 1.5rem;
    height: 1.5rem;
    background: var(--colonial);
    border-radius: 50%;
    border: none;
    margin-top: -0.5rem;
    cursor: pointer;
  }

  input[type=range]::-moz-range-thumb {
    width: 1.5rem;
    height: 1.5rem;
    background: var(--colonial);
    border-radius: 50%;
    border: none;
    cursor: pointer;
  }

  .insight {
    border-top: 0.0625rem solid var(--bronze);
    padding-top: 1.25rem;
  }

  .insight ul {
    color: var(--teak);
    font-size: var(--text-sm);
    line-height: 1.9;
    padding-left: 1.125rem;
  }

  .insight li strong {
    color: var(--parchment);
    font-weight: normal;
  }
</style>
