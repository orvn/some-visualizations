---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadGlobal, loadPage } from '../../lib/content';

const global = loadGlobal();
const { meta, content } = loadPage('confidence');
const c = content as {
  heading: string;
  eyebrow: string;
  subtitle: string;
};

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: c.heading,
  description: meta.description,
  url: global.url + '/concept/confidence',
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
>

  <section class="viz-wrap">
    <div class="viz-container" x-data="confidenceViz">

      <p class="eyebrow">{c.eyebrow}</p>
      <h1>{c.heading}</h1>
      <p class="subtitle">{c.subtitle}</p>

      <div class="card">
        <div class="card-header">
          <p class="card-label">50 experiments</p>
          <div class="coverage-stats">
            <span class="stat-captured" x-text="captured + ' captured'"></span>
            <span class="stat-missed" x-text="missed + ' missed'"></span>
            <span class="stat-pct" x-text="pct + '% coverage'"></span>
          </div>
        </div>

        <div class="controls-row">
          <div class="slider-row">
            <span class="slider-val" x-text="'n = ' + n"></span>
            <input type="range" min="5" max="200" step="5"
                   x-model="n"
                   x-on:change="simulate()" />
          </div>
          <div class="slider-row">
            <span class="slider-val" x-text="'1−α = ' + (parseFloat(confidence) * 100).toFixed(0) + '%'"></span>
            <input type="range" min="0.5" max="0.99" step="0.01"
                   x-model="confidence"
                   x-on:change="simulate()" />
          </div>
          <button class="button-viz" x-on:click="simulate()">Resample</button>
        </div>

        <canvas id="ci-chart" class="ci-canvas"></canvas>

        <div class="slider-row theta-row">
          <span class="slider-val" x-text="'true parameter θ = ' + parseFloat(theta).toFixed(1)"></span>
          <input type="range" min="-3" max="3" step="0.1"
                 x-model="theta"
                 x-on:change="simulate()" />
        </div>
      </div>

      <div class="insight">
        <p class="card-label">Key ideas</p>
        <ul>
          <li><strong>A 95% CI does not mean</strong> there's a 95% chance $\mu$ is inside this interval. $\mu$ is fixed.</li>
          <li><strong>It means:</strong> if you repeat the experiment many times, ~95% of intervals will capture $\mu$.</li>
          <li><strong>Larger n</strong> $\to$ narrower intervals (more precise), same coverage rate.</li>
          <li><strong>Higher confidence</strong> $\to$ wider intervals (less precise), fewer misses.</li>
        </ul>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .card-header {
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .coverage-stats {
    display: flex;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .stat-captured { color: var(--olivine); }
  .stat-missed { color: var(--sienna); }
  .stat-pct { color: var(--colonial); }

  .theta-row {
    margin-top: 0.5rem;
  }

  .ci-canvas {
    display: block;
    width: 100%;
    height: 28rem;
  }

  .controls-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .slider-row {
    gap: 0.75rem;
    flex: 1;
    min-width: 10rem;
  }

  .slider-val {
    font-size: var(--text-sm);
    min-width: 3.5rem;
    white-space: nowrap;
  }

  .button-viz {
    flex-shrink: 0;
  }

  @media (max-width: 30em) {
    .controls-row {
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
    }

    .slider-row {
      min-width: 0;
    }

    .button-viz {
      align-self: flex-end;
    }

    .theta-row .slider-val {
      font-size: var(--text-xs);
    }
  }
</style>
