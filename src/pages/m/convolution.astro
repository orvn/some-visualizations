---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TabNav from '../../components/TabNav.astro';
import { loadGlobal, loadPage } from '../../lib/content';

const global = loadGlobal();
const { meta, content } = loadPage('convolution');
const c = content as {
  heading: string;
  eyebrow: string;
  subtitle: string;
};

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: c.heading,
  description: meta.description,
  url: global.url + '/m/convolution',
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
>

  <section class="viz-wrap">
    <div class="viz-container" x-data="convolutionViz">

      <p class="eyebrow">{c.eyebrow}</p>
      <h1>{c.heading}</h1>
      <p class="subtitle">{c.subtitle}</p>

      <div class="card">
        <div class="card-controls" x-on:change="stop(); updateStatic()">
          <TabNav
            modelField="pair"
            options={[
              { value: 'uniform-uniform', label: 'Unif + Unif' },
              { value: 'uniform-exponential', label: 'Unif + Exp' },
              { value: 'triangle-uniform', label: 'Tri + Unif' },
            ]}
          />
        </div>

        <p class="card-label">Flip and slide: f(x) and g(z−x)</p>
        <canvas id="conv-chart"></canvas>

        <div class="slider-row">
          <span class="slider-val" x-text="'z = ' + zDisplay"></span>
          <input type="range"
                 min="-2" max="4" step="0.02"
                 x-model="z"
                 x-on:input="stop(); updateStatic()"
                 x-bind:disabled="playing" />
          <button class="btn-play" x-on:click="playing ? stop() : play()" x-text="playing ? 'Stop' : 'Animate'"></button>
        </div>
      </div>

      <div class="card">
        <p class="card-label" x-text="'Result: ' + resultLabel">Result</p>
        <canvas id="conv-result"></canvas>
      </div>

      <div class="insight">
        <p class="card-label">How it works</p>
        <ul>
          <li><strong>f * g(z) = ∫ f(x)·g(z−x) dx</strong>. Flip g, slide it by z, multiply with f, and integrate the overlap.</li>
          <li><strong>Uniform + Uniform = Triangle.</strong> The overlap area grows linearly then shrinks, forming a triangle.</li>
          <li><strong>The green area</strong> in the top chart is the integrand at each position. Its total area equals the result value at that z.</li>
          <li><strong>Order doesn't matter:</strong> f * g = g * f. Convolution is commutative.</li>
        </ul>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .viz-wrap {
    padding-block: 2rem 4rem;
  }

  .viz-container {
    max-width: 54rem;
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .eyebrow {
    text-align: center;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--potters-clay);
    margin-bottom: 0.5rem;
  }

  h1 {
    text-align: center;
    font-size: var(--text-3xl);
    font-weight: normal;
    letter-spacing: var(--tracking-tight);
    margin-bottom: 0.5rem;
    color: var(--parchment);
  }

  .subtitle {
    text-align: center;
    color: var(--teak);
    font-size: var(--text-sm);
    margin-bottom: 1.75rem;
  }

  .card {
    background: var(--crow);
    border: 0.0625rem solid var(--bronze);
    border-radius: 0.75rem;
    padding: 1.25rem 1.25rem 0.875rem;
    margin-bottom: 1.25rem;
  }

  .card-controls {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 0.75rem;
  }

  .card-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--potters-clay);
    margin-bottom: 0.5rem;
  }

  canvas {
    display: block;
    width: 100% !important;
  }

  .slider-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.875rem;
    flex-wrap: wrap;
  }

  .slider-val {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: bold;
    color: var(--colonial);
    min-width: 4rem;
  }

  @media (max-width: 30em) {
    .slider-row {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.5rem;
    }

    .slider-val {
      min-width: auto;
      font-size: var(--text-sm);
    }

    .slider-row :global(.btn-play) {
      grid-column: 1 / -1;
      justify-self: end;
    }
  }

  input[type=range] {
    -webkit-appearance: none;
    appearance: none;
    flex: 1;
    cursor: pointer;
    height: 0.5rem;
    background: transparent;
    padding: 0.75rem 0;
    margin: 0;
  }

  input[type=range]::-webkit-slider-runnable-track {
    height: 0.5rem;
    background: var(--bronze);
    border-radius: 0.25rem;
  }

  input[type=range]::-moz-range-track {
    height: 0.5rem;
    background: var(--bronze);
    border-radius: 0.25rem;
    border: none;
  }

  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 1.5rem;
    height: 1.5rem;
    background: var(--colonial);
    border-radius: 50%;
    border: none;
    margin-top: -0.5rem;
    cursor: pointer;
  }

  input[type=range]::-moz-range-thumb {
    width: 1.5rem;
    height: 1.5rem;
    background: var(--colonial);
    border-radius: 50%;
    border: none;
    cursor: pointer;
  }

  .btn-play {
    padding: 0.375rem 1rem;
    background: var(--bronze);
    border: 0.0625rem solid var(--potters-clay);
    border-radius: 0.375rem;
    color: var(--parchment);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background-color var(--transition-fast);
    white-space: nowrap;
  }

  .btn-play:hover {
    background: var(--potters-clay);
  }

  .insight {
    border-top: 0.0625rem solid var(--bronze);
    padding-top: 1.25rem;
  }

  .insight ul {
    color: var(--teak);
    font-size: var(--text-sm);
    line-height: 1.9;
    padding-left: 1.125rem;
  }

  .insight li strong {
    color: var(--parchment);
    font-weight: normal;
  }
</style>
