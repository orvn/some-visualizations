---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadGlobal, loadPage } from '../../lib/content';

const global = loadGlobal();
const { meta, content } = loadPage('covariance');
const c = content as {
  heading: string;
  eyebrow: string;
  subtitle: string;
};

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: c.heading,
  description: meta.description,
  url: global.url + '/m/covariance',
};
---

<BaseLayout
  title={meta.title ?? undefined}
  description={meta.description}
  ogImage={meta.og_image}
  jsonLD={jsonLD}
>

  <section class="viz-wrap">
    <div class="viz-container" x-data="correlationViz">

      <p class="eyebrow">{c.eyebrow}</p>
      <h1>{c.heading}</h1>
      <p class="subtitle">{c.subtitle}</p>

      <div class="card">
        <div class="card-label-row">
          <p class="card-label">Joint distribution (σₓ = σᵧ = 1, zero-mean)</p>
        </div>

        <div class="chart-area">
          <canvas id="corr-chart"></canvas>
          <div class="matrix-overlay" aria-label="Covariance matrix">
            <p class="matrix-title">Σ</p>
            <div class="matrix-body">
              <div class="matrix-bracket left"></div>
              <div class="matrix-cells">
                <span>1</span>
                <span class="rho-val" x-text="parseFloat(rho).toFixed(2)" x-bind:style="'color:' + accentColor"></span>
                <span class="rho-val" x-text="parseFloat(rho).toFixed(2)" x-bind:style="'color:' + accentColor"></span>
                <span>1</span>
              </div>
              <div class="matrix-bracket right"></div>
            </div>
          </div>
        </div>

        <div class="slider-row">
          <span class="slider-val" x-text="'ρ = ' + parseFloat(rho).toFixed(2)" x-bind:style="'color:' + accentColor"></span>
          <input type="range" min="-0.99" max="0.99" step="0.01"
                 x-model="rho"
                 x-on:input="render()" />
        </div>
      </div>

      <div class="insight">
        <p class="card-label">Key ideas</p>
        <ul>
          <li><strong>cov(X,Y) = 𝔼[(X−𝔼[X])·(Y−𝔼[Y])]</strong>. Positive when deviations share a sign, negative when they oppose.</li>
          <li><strong>ρ = cov(X,Y) / σₓσᵧ</strong> is the dimensionless version, always between −1 and 1.</li>
          <li><strong>cov(X,Y) = 0 does not imply independence.</strong> X and Y can be dependent with zero covariance (e.g., Y = X²).</li>
          <li><strong>Independence does imply zero covariance</strong>, but not the other way around.</li>
        </ul>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .viz-wrap {
    padding-block: 2rem 4rem;
  }

  .viz-container {
    max-width: 42rem;
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .eyebrow {
    text-align: center;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--potters-clay);
    margin-bottom: 0.5rem;
  }

  h1 {
    text-align: center;
    font-size: var(--text-3xl);
    font-weight: normal;
    letter-spacing: var(--tracking-tight);
    margin-bottom: 0.5rem;
    color: var(--parchment);
  }

  .subtitle {
    text-align: center;
    color: var(--teak);
    font-size: var(--text-sm);
    margin-bottom: 1.75rem;
  }

  .card {
    background: var(--crow);
    border: 0.0625rem solid var(--bronze);
    border-radius: 0.75rem;
    padding: 1.25rem 1.25rem 0.875rem;
    margin-bottom: 1.25rem;
  }

  .card-label-row {
    margin-bottom: 0.5rem;
  }

  .card-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--potters-clay);
  }

  .chart-area {
    position: relative;
  }

  canvas {
    display: block;
    width: 100% !important;
  }

  .matrix-overlay {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: rgba(26, 12, 6, 0.85);
    border: 0.0625rem solid var(--bronze);
    border-radius: 0.375rem;
    padding: 0.625rem 0.75rem;
  }

  @media (max-width: 30em) {
    .matrix-overlay {
      top: -1.25rem;
      right: -0.75rem;
      padding: 0.375rem 0.5rem;
      transform: scale(0.85);
      transform-origin: top right;
    }
  }

  .matrix-title {
    font-family: var(--font-display);
    font-style: normal;
    font-size: var(--text-lg);
    color: var(--parchment);
    text-align: center;
    margin-bottom: 0.25rem;
  }

  .matrix-body {
    display: flex;
    align-items: stretch;
    gap: 0.25rem;
  }

  .matrix-bracket {
    width: 0.1875rem;
    border: 0.0625rem solid var(--potters-clay);
  }

  .matrix-bracket.left {
    border-right: none;
    border-radius: 0.125rem 0 0 0.125rem;
  }

  .matrix-bracket.right {
    border-left: none;
    border-radius: 0 0.125rem 0.125rem 0;
  }

  .matrix-cells {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.125rem 0.75rem;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--teak);
    text-align: center;
    padding: 0.25rem 0.25rem;
  }

  .rho-val {
    color: var(--colonial);
  }

  .slider-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.875rem;
  }

  .slider-val {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: bold;
    color: var(--colonial);
    min-width: 5.5rem;
  }

  input[type=range] {
    -webkit-appearance: none;
    appearance: none;
    flex: 1;
    cursor: pointer;
    height: 0.5rem;
    background: transparent;
    padding: 0.75rem 0;
    margin: 0;
  }

  input[type=range]::-webkit-slider-runnable-track {
    height: 0.5rem;
    background: var(--bronze);
    border-radius: 0.25rem;
  }

  input[type=range]::-moz-range-track {
    height: 0.5rem;
    background: var(--bronze);
    border-radius: 0.25rem;
    border: none;
  }

  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 1.5rem;
    height: 1.5rem;
    background: var(--colonial);
    border-radius: 50%;
    border: none;
    margin-top: -0.5rem;
    cursor: pointer;
  }

  input[type=range]::-moz-range-thumb {
    width: 1.5rem;
    height: 1.5rem;
    background: var(--colonial);
    border-radius: 50%;
    border: none;
    cursor: pointer;
  }

  .insight {
    border-top: 0.0625rem solid var(--bronze);
    padding-top: 1.25rem;
  }

  .insight ul {
    color: var(--teak);
    font-size: var(--text-sm);
    line-height: 1.9;
    padding-left: 1.125rem;
  }

  .insight li strong {
    color: var(--parchment);
    font-weight: normal;
  }
</style>
