---
interface Option {
  value: string;
  label: string;
}

interface Props {
  options: Option[];
  modelField?: string;
  placeholder?: string;
}

const { options, modelField = 'selected', placeholder = 'Select' } = Astro.props;
---

<div
  class="dropdown"
  x-data="{ open: false }"
  x-on:click.outside="open = false"
  x-on:keydown.escape="open = false"
>
  <button
    type="button"
    class="dropdown-trigger"
    x-on:click="open = !open"
    aria-haspopup="listbox"
    x-bind:aria-expanded="String(open)"
  >
    <span
      class="dropdown-label"
      x-text={`${JSON.stringify(options)}.find(o => o.value === ${modelField})?.label || '${placeholder}'`}
    ></span>
    <svg class="dropdown-chevron" x-bind:class="{ 'is-open': open }" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
      <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <ul
    class="dropdown-menu"
    role="listbox"
    x-show="open"
    x-transition:enter="menu-enter"
    x-transition:enter-start="menu-hidden"
    x-transition:enter-end="menu-visible"
    x-transition:leave="menu-leave"
    x-transition:leave-start="menu-visible"
    x-transition:leave-end="menu-hidden"
    x-cloak
  >
    {options.map((opt) => (
      <li
        role="option"
        class="dropdown-item"
        x-bind:class={`{ 'is-selected': ${modelField} === '${opt.value}' }`}
        x-on:click={`${modelField} = '${opt.value}'; open = false; $dispatch('change')`}
        x-bind:aria-selected={`String(${modelField} === '${opt.value}')`}
      >
        {opt.label}
      </li>
    ))}
  </ul>
</div>

<style>
  .dropdown {
    position: relative;
    display: inline-block;
  }

  .dropdown-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.625rem;
    background: var(--graphite);
    border: 0.0625rem solid var(--bronze);
    border-radius: 0.375rem;
    color: var(--parchment);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    cursor: pointer;
    transition: border-color var(--transition-fast);
    white-space: nowrap;
  }

  .dropdown-trigger:hover {
    border-color: var(--potters-clay);
  }

  .dropdown-chevron {
    color: var(--potters-clay);
    transition: transform var(--transition-fast);
    flex-shrink: 0;
  }

  .dropdown-chevron.is-open {
    transform: rotate(180deg);
  }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 0.375rem);
    right: 0;
    min-width: 100%;
    background: var(--crow);
    border: 0.0625rem solid var(--bronze);
    border-radius: 0.375rem;
    box-shadow: var(--shadow-lg);
    padding: 0.25rem;
    z-index: var(--z-above);
    list-style: none;
    margin: 0;
  }

  .menu-enter,
  .menu-leave {
    transition: opacity var(--transition-fast), transform var(--transition-fast);
  }

  .menu-hidden {
    opacity: 0;
    transform: translateY(-0.25rem);
  }

  .menu-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .dropdown-item {
    padding: 0.375rem 0.625rem;
    border-radius: 0.25rem;
    color: var(--teak);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    cursor: pointer;
    transition: background-color var(--transition-fast), color var(--transition-fast);
    white-space: nowrap;
  }

  .dropdown-item:hover {
    background: var(--bronze);
    color: var(--parchment);
  }

  .dropdown-item.is-selected {
    color: var(--colonial);
  }
</style>
