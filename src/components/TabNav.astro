---
interface Option {
  value: string;
  label: string;
}

interface Props {
  options: Option[];
  modelField?: string;
}

const { options, modelField = 'selected' } = Astro.props;
const count = options.length;
---

<div
  class="toggle-track"
  x-data={`{ _idx: 0 }`}
  x-effect={`_idx = ${JSON.stringify(options.map(o => o.value))}.indexOf(${modelField})`}
>
  {options.map((opt) => (
    <button
      type="button"
      class="toggle-option"
      x-bind:class={`{ 'is-active': ${modelField} === '${opt.value}' }`}
      x-on:click={`${modelField} = '${opt.value}'; $dispatch('change')`}
    >{opt.label}</button>
  ))}
  <span
    class="toggle-thumb"
    aria-hidden="true"
    x-init={`$nextTick(() => {
      let btns = [...$el.parentElement.querySelectorAll('.toggle-option')];
      function pos() {
        let b = btns[_idx];
        if (!b) return;
        $el.style.width = b.offsetWidth + 'px';
        $el.style.left = b.offsetLeft + 'px';
      }
      pos();
      $watch('_idx', () => pos());
    })`}
  ></span>
</div>

<style is:global>
  .toggle-track {
    position: relative;
    display: inline-flex;
    background: var(--graphite);
    border: 0.0625rem solid var(--bronze);
    border-radius: 0.5rem;
    padding: 0.1875rem;
    gap: 0;
  }

  .toggle-option {
    position: relative;
    z-index: 1;
    padding: 0.375rem 1rem;
    border: none;
    border-radius: 0.375rem;
    background: transparent;
    color: var(--potters-clay);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: color var(--transition-fast);
    white-space: nowrap;
  }

  .toggle-option.is-active {
    color: var(--parchment);
    font-weight: 600;
  }

  .toggle-option:not(.is-active):hover {
    color: var(--teak);
  }

  .toggle-thumb {
    position: absolute;
    top: 0.1875rem;
    height: calc(100% - 0.375rem);
    background: var(--potters-clay);
    border: none;
    border-radius: 0.375rem;
    transition: left var(--transition-base);
    pointer-events: none;
  }
</style>
